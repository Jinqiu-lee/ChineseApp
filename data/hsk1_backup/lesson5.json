  "grammar_point": {
    "title": "怎么 (zěnme) — How",
    "explanation": "怎么 asks 'how' about methods or manner. 你怎么去 = How are you going? The transport verb 坐 is used for vehicles you sit inside (bus, train, plane, taxi). 骑 is used for things you ride on top of (bike, horse, motorbike). 开 means to drive.",
    "examples": [
      { "chinese": "你怎么来的？", "pinyin": "Nǐ zěnme lái de?", "english": "How did you come / get here?" },
      { "chinese": "我骑自行车来的", "pinyin": "Wǒ qí zìxíngchē lái de", "english": "I came by bicycle" }
    ]
  },
