  "grammar_point": {
    "title": "Date expressions: Year-Month-Date order",
    "explanation": "Chinese dates go from largest to smallest unit: 年(year) → 月(month) → 号(date). E.g. 2024年3月15号 = March 15, 2024. This is the opposite of British English (15 March 2024) and different from American English (March 15, 2024). Time also goes: 下午两点三十分 (PM 2:30).",
    "examples": [
      { "chinese": "2024年6月1号", "pinyin": "Èr líng èr sì nián liù yuè yī hào", "english": "June 1, 2024" },
      { "chinese": "上午十点二十分", "pinyin": "Shàngwǔ shí diǎn èrshí fēn", "english": "10:20 AM" },
      { "chinese": "2025年1月30日 早上10点", "pinyin": "èr líng ér wǔ nián yī yuè sān shí rì zǎo shàng shí diǎn", "english": "January 30, 2025, 10:00 AM" }
    ]
