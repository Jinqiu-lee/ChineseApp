  "grammar_point": {
    "title": "Asking and saying names with 叫",
    "explanation": "Use 叫 (jiào) to say what someone is called. The pattern is: [person] + 叫 + [name]. To ask someone's name: 你叫什么名字？ (What are you called?)",
    "examples": [
      { "chinese": "我叫大卫", "pinyin": "Wǒ jiào Dàwèi", "english": "My name is David" },
      { "chinese": "她叫安娜", "pinyin": "Tā jiào Ānnà", "english": "Her name is Anna" }
    ]
  },
