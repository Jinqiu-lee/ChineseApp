  "grammar_point": {
    "title": "Days of the week — 星期 + number",
    "explanation": "Chinese days of the week are logical: 星期 (xīngqī = week) + number 1–6 for Monday to Saturday. Sunday is special: 星期天 or 星期日. To ask 'what day?', say 星期几 (which number of the week?). Time words go before the verb in Chinese sentences.",
    "examples": [
      { "chinese": "昨天星期一", "pinyin": "Zuótiān xīngqī yī", "english": "Yesterday was Monday" },
      { "chinese": "他星期五来", "pinyin": "Tā xīngqī wǔ lái", "english": "He comes on Friday" }
    ]
