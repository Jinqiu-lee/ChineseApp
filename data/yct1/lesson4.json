  "grammar_point": {
    "title": "有 (yǒu) — to have",
    "explanation": "有 means 'have' or 'there is'. The negative form is 没有 (méi yǒu) — 'don't have'. To ask 'how many', use 几 (jǐ) for small numbers. 口 is the measure word used specifically for counting family members.",
    "examples": [
      { "chinese": "我有一个弟弟", "pinyin": "Wǒ yǒu yí gè dìdi", "english": "I have a younger brother" },
      { "chinese": "我没有妹妹", "pinyin": "Wǒ méiyǒu mèimei", "english": "I don't have a younger sister" }
    ]
