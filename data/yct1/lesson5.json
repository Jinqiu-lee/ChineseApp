  "grammar_point": {
    "title": "Saying age with 岁 (suì)",
    "explanation": "To say your age in Chinese: [number] + 岁. No verb needed! 我六岁 literally means 'I six years-old'. To ask age, use 几岁 (how many years old). Numbers 1–10 are the foundation for all larger numbers in Chinese.",
    "examples": [
      { "chinese": "我七岁", "pinyin": "Wǒ qī suì", "english": "I am seven years old" },
      { "chinese": "她十岁", "pinyin": "Tā shí suì", "english": "She is ten years old" }
    ]
  },
