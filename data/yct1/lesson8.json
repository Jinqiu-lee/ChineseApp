  "grammar_point": {
    "title": "Expressing movement with 去 (qù) and 来 (lái)",
    "explanation": "去 means 'to go (away from speaker)' and 来 means 'to come (toward speaker)'. The sentence structure is: [subject] + 去/来 + [place]. No extra words needed — much simpler than English!",
    "examples": [
      { "chinese": "我去公园", "pinyin": "Wǒ qù gōngyuán", "english": "I'm going to the park" },
      { "chinese": "她去医院", "pinyin": "Tā qù yīyuàn", "english": "She is going to the hospital" }
    ]
  },
