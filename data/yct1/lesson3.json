  "grammar_point": {
    "title": "Using 是 (shì) — the verb 'to be'",
    "explanation": "是 (shì) means 'is/am/are'. Use it to identify people or things. To say 'is not', add 不 before 是 → 不是 (bú shì). The possessive particle 的 (de) means 'of' or 's — e.g. 我的 = my.",
    "examples": [
      { "chinese": "我是学生", "pinyin": "Wǒ shì xuésheng", "english": "I am a student" },
      { "chinese": "他不是老师", "pinyin": "Tā bú shì lǎoshī", "english": "He is not a teacher" }
    ]
  },
