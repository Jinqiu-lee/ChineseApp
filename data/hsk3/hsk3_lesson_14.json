      "lines": [
        {"speaker": "A", "chinese": "大明，你能帮我把这些箱子搬进去吗？", "pinyin": "Dà Míng, nǐ néng bāng wǒ bǎ zhè xiē xiāng zi bān jìn qù ma?", "english": "Daming, can you help me carry these boxes inside?"},
        {"speaker": "B", "chinese": "可以，放哪里？", "pinyin": "Kě yǐ, fàng nǎ lǐ?", "english": "Sure, where should they go?"},
        {"speaker": "A", "chinese": "请把它们搬到楼上去，放在书房里。", "pinyin": "Qǐng bǎ tā men bān dào lóu shàng qù, fàng zài shū fáng lǐ.", "english": "Please carry them upstairs and put them in the study."},
        {"speaker": "B", "chinese": "好的，那本书也要带过来吗？", "pinyin": "Hǎo de, nà běn shū yě yào dài guò lái ma?", "english": "Sure. Should I also bring that book over here?"},
        {"speaker": "A", "chinese": "对，把书也搬上来，谢谢你！", "pinyin": "Duì, bǎ shū yě bān shàng lái, xiè xie nǐ!", "english": "Yes, bring the books up too — thank you!"},
        {"speaker": "B", "chinese": "没问题，我把所有东西都搬进去。", "pinyin": "Méi wèn tí, wǒ bǎ suǒ yǒu dōng xi dōu bān jìn qù.", "english": "No problem — I'll carry everything inside."}
      ]
    },
    {
      "id": 2,
      "title": "Giving Directions Inside a Building",
      "title_chinese": "在楼里指路",
      "speakers": {
        "A": {"name": "小红", "role": "同事", "gender": "female"},
        "B": {"name": "大明", "role": "同事", "gender": "male"}
      },
      "lines": [
        {"speaker": "A", "chinese": "会议室在哪儿？我找不到。", "pinyin": "Huì yì shì zài nǎr? Wǒ zhǎo bú dào.", "english": "Where's the meeting room? I can't find it."},
        {"speaker": "B", "chinese": "你走进来之后，往左边走过去。", "pinyin": "Nǐ zǒu jìn lái zhī hòu, wǎng zuǒ biān zǒu guò qù.", "english": "After you walk in, go over to the left."},
        {"speaker": "A", "chinese": "然后呢？上楼还是下楼？", "pinyin": "Rán hòu ne? Shàng lóu hái shì xià lóu?", "english": "Then what? Go up or down?"},
        {"speaker": "B", "chinese": "坐电梯上来，到三楼，然后往右走出去。", "pinyin": "Zuò diàn tī shàng lái, dào sān lóu, rán hòu wǎng yòu zǒu chū qù.", "english": "Take the elevator up to the third floor, then walk out to the right."},
        {"speaker": "A", "chinese": "好的，我看起来可能要走错了，你带我过去吧！", "pinyin": "Hǎo de, wǒ kàn qǐ lái kě néng yào zǒu cuò le, nǐ dài wǒ guò qù ba!", "english": "OK, it looks like I might get lost — just take me there!"},
        {"speaker": "B", "chinese": "哈哈，好吧，我带你过去。走，跟我来！", "pinyin": "Hā hā, hǎo ba, wǒ dài nǐ guò qù. Zǒu, gēn wǒ lái!", "english": "Ha ha, OK then — I'll take you there. Come on, follow me!"}
      ]
    }
