  "grammar_points": [
    {
      "number": 1,
      "title": "趋向补语 — Directional Complements",
      "explanation": "Verbs of motion + 来/去 or compound directional complements. 来 = towards speaker. 去 = away from speaker. Simple: 进来, 出去. Compound: 走进来 (walk in towards speaker), 跑出去 (run out away). The direction is always from the speaker's perspective.",
      "examples": [
        {
          "chinese": "他跑进来了。",
          "pinyin": "Tā pǎo jìn lái le.",
          "english": "He ran inside (towards me)."
        },
        {
          "chinese": "她走出去了。",
          "pinyin": "Tā zǒu chū qù le.",
          "english": "She walked out (away from me)."
        }
      ],
      "exercises": [
        {
          "question": "What does 来 indicate in a directional complement?",
          "type": "multiple_choice",
          "correct": "Movement towards the speaker",
          "options": [
