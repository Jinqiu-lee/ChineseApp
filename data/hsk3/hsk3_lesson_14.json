  "grammar_points": [
    {
      "number": 1,
      "title": "趋向补语 — Directional Complements",
      "explanation": "Verbs of motion + 来/去 or compound directional complements. 来 = towards speaker. 去 = away from speaker. Simple: 进来, 出去. Compound: 走进来 (walk in towards speaker), 跑出去 (run out away). The direction is always from the speaker's perspective.",
      "examples": [
        {
          "chinese": "他跑进来了。",
          "pinyin": "Tā pǎo jìn lái le.",
          "english": "He ran in (towards me)."
        },
        {
          "chinese": "她走出去了。",
          "pinyin": "Tā zǒu chū qù le.",
          "english": "She walked out (away from me)."
        }
      ],
      "exercises": [
        {
          "question": "What does 来 indicate in a directional complement?",
          "type": "multiple_choice",
          "correct": "Movement towards the speaker",
          "options": [
            "Movement towards the speaker",
            "Movement away from the speaker",
            "Upward movement",
            "Downward movement"
          ]
        },
        {
          "question": "Which means 'go in (away from speaker)'?",
          "type": "multiple_choice",
          "correct": "进去",
          "options": ["进去", "进来", "出来", "出去"],
          "option_pinyin": ["jìn qù", "jìn lái", "chū lái", "chū qù"]
        },
        {
          "question": "Fill in: 他跑___了。(He ran in towards me.)",
          "type": "multiple_choice",
          "correct": "进来",
          "options": ["进来", "出去", "回去", "上去"],
          "option_pinyin": ["jìn lái", "chū qù", "huí qù", "shàng qù"]
        },
        {
          "question": "Which is a compound directional complement?",
          "type": "multiple_choice",
          "correct": "走进来",
          "options": ["走进来", "进", "来", "走"],
          "option_pinyin": ["zǒu jìn lái", "jìn", "lái", "zǒu"]
        },
        {
          "question": "Whose perspective determines 来 or 去?",
          "type": "multiple_choice",
          "correct": "The speaker's",
          "options": ["The speaker's", "The listener's", "A third person's", "The subject's"]
        }
      ]
    },
    {
      "number": 2,
      "title": "把字句 + 趋向补语 — Bǎ-sentence with Directional Complement",
      "explanation": "Subject + 把 + Object + Verb + Directional complement. 请把水果拿过来 = Please bring the fruit over here. 把书搬进去 = Carry the books inside. The 把 + directional combination is very common for physical movement of objects.",
      "examples": [
        {
          "chinese": "请把水果拿过来。",
          "pinyin": "Qǐng bǎ shuǐ guǒ ná guò lái.",
          "english": "Please bring the fruit over here."
        },
        {
          "chinese": "他把行李搬上来了。",
          "pinyin": "Tā bǎ xíng lǐ bān shàng lái le.",
          "english": "He carried the luggage upstairs."
        }
      ],
      "exercises": [
        {
          "question": "Fill in: 请___水果拿过来。(Please bring the fruit here.)",
          "type": "multiple_choice",
          "correct": "把",
          "options": ["把", "被", "让", "在"],
          "option_pinyin": ["bǎ", "bèi", "ràng", "zài"]
        },
        {
          "question": "Which is a correct 把 + directional sentence?",
          "type": "multiple_choice",
          "correct": "把书搬进去。",
          "options": ["把书搬进去。", "书把搬进去。", "把进去搬书。", "搬书把进去。"],
          "option_pinyin": [
            "Bǎ shū bān jìn qù.",
            "Shū bǎ bān jìn qù.",
            "Bǎ jìn qù bān shū.",
            "Bān shū bǎ jìn qù."
          ],
          "correct_pinyin": "Bǎ shū bān jìn qù."
        },
        {
          "question": "Translate: 把椅子搬出去。",
          "type": "multiple_choice",
          "correct": "Carry the chairs outside.",
          "options": ["Carry the chairs outside.", "Bring the chairs in.", "Put the chairs down.", "Lift the chairs up."]
        },
        {
          "question": "In a 把 + directional sentence, what follows the verb?",
          "type": "multiple_choice",
          "correct": "The directional complement",
          "options": [
            "The directional complement",
            "Another subject",
            "A question word",
            "A time expression"
          ]
        },
        {
          "question": "What type of action is 把 + directional most used for?",
          "type": "multiple_choice",
          "correct": "Physical movement of objects",
          "options": [
            "Physical movement of objects",
            "Mental activities",
            "States and conditions",
            "Future plans"
          ]
        }
      ]
    },
    {
      "number": 3,
      "title": "起来 的特殊用法 — Special Use of 起来",
      "explanation": "Beyond literal 'rise up', 起来 after a verb can mean 'start to' (action begins): 唱起来 = start singing. 笑起来 = start laughing. 看起来 (standalone) = seem/look like. 听起来 = sound like. These extended uses are very common in everyday speech.",
      "examples": [
        {
          "chinese": "她突然哭起来了。",
          "pinyin": "Tā tū rán kū qǐ lái le.",
          "english": "She suddenly started crying."
        },
        {
          "chinese": "这个菜看起来很好吃。",
          "pinyin": "Zhè gè cài kàn qǐ lái hěn hǎo chī.",
          "english": "This dish looks delicious."
        }
      ],
      "exercises": [
        {
          "question": "What does 唱起来 mean?",
          "type": "multiple_choice",
          "correct": "Start singing",
          "options": ["Start singing", "Stop singing", "Sing well", "Sing loudly"]
        },
        {
          "question": "What does 看起来 mean as a standalone phrase?",
          "type": "multiple_choice",
          "correct": "Seem / Look like",
          "options": ["Seem / Look like", "Start looking", "Look up", "Stand up and look"]
        },
        {
          "question": "Fill in: 大家都___来了，气氛很好。(Everyone started laughing.)",
          "type": "multiple_choice",
          "correct": "笑起",
          "options": ["笑起", "哭起", "跑起", "走起"],
          "option_pinyin": ["xiào qǐ", "kū qǐ", "pǎo qǐ", "zǒu qǐ"]
        },
        {
          "question": "What does 听起来 mean?",
          "type": "multiple_choice",
          "correct": "Sound like",
          "options": ["Sound like", "Start listening", "Listen carefully", "Hear clearly"]
        },
        {
          "question": "Translate: 这件事听起来很有意思。",
