  "grammar_point": {
    "title": "应该 (yīnggāi) — should / ought to",
    "explanation": "应该 means 'should' and expresses advice or obligation. Place it before a verb: 你应该休息 = you should rest. 有点 (yǒudiǎn) before an adjective means 'a little' or 'slightly': 有点疼 = a little painful. These are very useful for real-life health conversations.",
    "examples": [
      { "chinese": "你应该多运动", "pinyin": "Nǐ yīnggāi duō yùndòng", "english": "You should exercise more" },
      { "chinese": "我有点累", "pinyin": "Wǒ yǒudiǎn lèi", "english": "I'm a little tired" }
    ]
  },
