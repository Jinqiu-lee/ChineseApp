  "key_sentences": [
    { "chinese": "你哪里不舒服？", "pinyin": "Nǐ nǎlǐ bù shūfu?", "english": "Where do you feel unwell?" },
    { "chinese": "我头疼，还有点发烧。", "pinyin": "Wǒ tóuténg, hái yǒudiǎn fāshāo.", "english": "I have a headache and a slight fever." },
