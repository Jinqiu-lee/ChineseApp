    {
      "number": 3,
      "title": "Question particle 吗 (ma)",
      "explanation": "吗 (ma) is added at the end of a statement to turn it into a yes/no question. Formula: Statement + 吗？",
      "examples": [
        {
          "chinese": "你是学生吗？",
          "pinyin": "Nǐ shì xué shēng ma?",
          "english": "Are you a student?"
        },
        {
          "chinese": "他好吗？",
          "pinyin": "Tā hǎo ma?",
          "english": "Is he well?"
        }
      ],
