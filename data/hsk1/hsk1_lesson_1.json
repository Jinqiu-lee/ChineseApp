  "grammar_points": [
    {
      "number": 1,
      "title": "Using 是 (shì) - The verb 'to be'",
      "explanation": "是 (shì) is used to link the subject with a noun or pronoun. It works like 'am/is/are' in English. Formula: Subject + 是 + Noun/Pronoun.",
      "examples": [
        {
          "chinese": "我是学生。",
          "pinyin": "Wǒ shì xué shēng.",
          "english": "I am a student."
        },
        {
          "chinese": "他是老师。",
          "pinyin": "Tā shì lǎo shī.",
          "english": "He is a teacher."
        }
      ],
      "exercises": [
        {
          "question": "Fill in the blank: 我___老师。(I am a teacher)",
          "type": "multiple_choice",
          "correct": "是",
          "options": [
            "是",
            "有",
            "在",
            "的"
          ],
          "option_pinyin": [
            "shì",
            "yǒu",
            "zài",
            "de"
          ]
        },
        {
          "question": "Which sentence means 'She is my friend'?",
          "type": "multiple_choice",
          "correct": "她是我的朋友。",
          "options": [
            "她是我的朋友。",
            "她有我的朋友。",
            "她在我的朋友。",
            "她的我朋友。"
          ],
          "option_pinyin": [
            "Tā shì wǒ de péng yǒu.",
            "Tā yǒu wǒ de péng yǒu.",
            "Tā zài wǒ de péng yǒu.",
            "Tā de wǒ péng yǒu."
          ],
          "correct_pinyin": "Tā shì wǒ de péng yǒu."
        },
        {
          "question": "What does 是 mean in English?",
          "type": "multiple_choice",
          "correct": "to be (am/is/are)",
          "options": [
            "to be (am/is/are)",
            "to have",
            "to go",
            "at/in/on"
          ]
        },
        {
          "question": "Choose the correct sentence: 'He is a student'",
          "type": "multiple_choice",
          "correct": "他是学生。",
          "options": [
            "他是学生。",
            "他有学生。",
            "他在学生。",
            "学生他是。"
          ],
          "option_pinyin": [
            "Tā shì xué shēng.",
            "Tā yǒu xué shēng.",
            "Tā zài xué shēng.",
            "Xué shēng tā shì."
          ],
          "correct_pinyin": "Tā shì xué shēng."
        }
      ]
    },
    {
      "number": 2,
      "title": "The possessive particle 的 (de)",
      "explanation": "的 (de) shows possession, like 's or 'of' in English. Formula: Possessor + 的 + Thing possessed.",
      "examples": [
        {
          "chinese": "我的书",
          "pinyin": "wǒ de shū",
          "english": "My book"
        },
        {
          "chinese": "他的名字",
          "pinyin": "tā de míng zi",
          "english": "His name"
        }
      ],
