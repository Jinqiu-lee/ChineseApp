  "grammar_points": [
    {
      "number": 1,
      "title": "Using 在 (zài) to indicate location",
      "explanation": "在(zài) is a preposition meaning 'at/in/on' for locations. It shows where something or someone is. Formula: Subject + 在(zài) + Place. Can also mean 'to be located at'.",
      "examples": [
        {
          "chinese": "我在家。",
          "pinyin": "Wǒ zài jiā.",
          "english": "I'm at home."
        },
        {
          "chinese": "猫在桌子下。",
          "pinyin": "Māo zài zhuō zi xià.",
          "english": "The cat is under the table."
        },
        {
          "chinese": "她不在这儿！",
          "pinyin": "Tā bú zài zhèr.",
          "english": "She is not here."
        }
      ],
      "exercises": [
        {
          "question": "Say 'I'm at school' in Chinese",
          "answer": "我在学校。",
          "type": "production"
        },
        {
          "question": "Fill in: 他___医院。(He is at the hospital)",
          "answer": "在",
          "type": "fill_in_blank"
        },
        {
          "question": "Fill in: 他___家。(He is not at home)",
          "answer": "不在",
          "type": "fill_in_blank"
        },
        {
          "question": "Translate: The book is in the room",
          "answer": "书在房间里。",
          "type": "translation"
        },
        {
          "question": "What preposition shows location in Chinese?",
          "answer": "在",
          "type": "concept"
        }
      ],
      "mini_exercises": [
