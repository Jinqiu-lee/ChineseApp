  "grammar_points": [
    {
      "number": 1,
      "title": "Using 在 (zài) to indicate location",
      "explanation": "在 (zài) is a preposition meaning 'at/in/on' for locations. It shows where something or someone is. Formula: Subject + 在 + Place. Can also mean 'to be located at'.",
      "examples": [
        {
          "chinese": "我在家。",
          "pinyin": "Wǒ zài jiā.",
          "english": "I'm at home."
        },
        {
          "chinese": "猫在桌子下。",
          "pinyin": "Māo zài zhuō zi xià.",
          "english": "The cat is under the table."
        }
      ],
      "exercises": [
        {
          "question": "Say 'I'm at school' in Chinese",
          "answer": "我在学校。",
          "type": "production"
        },
        {
          "question": "Fill in: 他___医院。(He is at the hospital)",
          "answer": "在",
          "type": "fill_in_blank"
        },
        {
          "question": "Translate: The book is in the room",
          "answer": "书在房间里。",
          "type": "translation"
        },
        {
          "question": "What preposition shows location in Chinese?",
          "answer": "在",
          "type": "concept"
        }
      ]
    },
    {
      "number": 2,
      "title": "Asking 'where' with 哪儿 (nǎr)",
      "explanation": "哪儿 (nǎr) means 'where' and is used to ask about locations. It replaces the place in a 在 sentence. Formula: Subject + 在 + 哪儿？ Some regions use 哪里 instead of 哪儿.",
      "examples": [
        {
          "chinese": "你在哪儿？",
          "pinyin": "Nǐ zài nǎr?",
          "english": "Where are you?"
        },
        {
          "chinese": "学校在哪儿？",
          "pinyin": "Xué xiào zài nǎr?",
          "english": "Where is the school?"
        }
      ],
      "exercises": [
        {
          "question": "Ask 'Where is he?' in Chinese",
          "answer": "他在哪儿？",
          "type": "production"
        },
        {
          "question": "Ask 'Where is the hospital?'",
          "answer": "医院在哪儿？",
          "type": "production"
        },
        {
          "question": "What word means 'where' in Chinese?",
          "answer": "哪儿",
          "type": "concept"
        },
        {
          "question": "Turn into a question: 书在桌子上。",
          "answer": "书在哪儿？",
          "type": "transformation"
        }
      ]
    },
    {
      "number": 3,
      "title": "Position words: 上, 下, 里, 前, 后",
      "explanation": "These are position words (localizers) that describe relative locations. They usually need 面 or 边 after them for common places. Formula: Noun + Position word + (面/边). 上=on/above, 下=below, 里=inside, 前=front, 后=back.",
      "examples": [
        {
          "chinese": "桌子上",
          "pinyin": "zhuō zi shàng",
          "english": "On the table"
        },
        {
          "chinese": "房间里",
          "pinyin": "fáng jiān lǐ",
          "english": "In the room"
        }
      ],
      "exercises": [
        {
          "question": "Say 'on the chair' in Chinese",
          "answer": "椅子上",
          "type": "production"
        },
        {
          "question": "What does 里 mean?",
          "answer": "inside/in",
          "type": "concept"
        },
        {
          "question": "Translate: Under the table",
          "answer": "桌子下",
          "type": "translation"
        },
        {
          "question": "Say 'in front of the school'",
          "answer": "学校前面",
          "type": "production"
        }
      ]
    }
  ],
