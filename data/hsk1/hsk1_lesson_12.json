  "grammar_points": [
    {
      "number": 1,
      "title": "Modal Verb 能 (néng) — Physical Ability / Permission",
      "explanation": "能(néng) expresses physical ability or situational permission. Differs from 会(learned skill). 能(néng) = 'can' because of circumstances. Negative: 不能(bù néng) -- cannot. Question: 能不能? or 能...吗?",
      "examples": [
        {
          "chinese": "你能来吗？",
          "pinyin": "Nǐ néng lái ma?",
          "english": "Can you come?"
        },
        {
          "chinese": "这里不能喝酒。",
          "pinyin": "Zhèlǐ bù néng hē jiǔ.",
          "english": "You can't drink alcohol here."
        }
      ],
      "exercises": [
        {
          "question": "Difference between 能 and 会?",
          "answer": "能 = situational ability/permission; 会 = learned skill",
          "type": "concept"
