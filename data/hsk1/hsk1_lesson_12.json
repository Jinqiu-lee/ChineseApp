  "grammar_points": [
    {
      "number": 1,
      "title": "Modal Verb 能 (néng) — Physical Ability / Permission",
      "explanation": "能 expresses physical ability or situational permission. Differs from 会 (learned skill). 能 = 'can' because of circumstances. Negative: 不能. Question: 能不能 or 能...吗?",
      "examples": [
        {
          "chinese": "你能来吗？",
          "pinyin": "Nǐ néng lái ma?",
          "english": "Can you come?"
        },
        {
          "chinese": "这里不能喝酒。",
          "pinyin": "Zhèlǐ bù néng hē jiǔ.",
          "english": "You can't drink alcohol here."
        }
      ],
      "exercises": [
        {
          "question": "Difference between 能 and 会?",
          "answer": "能 = situational ability/permission; 会 = learned skill",
          "type": "concept"
        },
        {
          "question": "Fill in: 我___来，但是他不能来。(I can come)",
          "answer": "能",
          "type": "fill_in_blank"
        }
      ]
    },
    {
      "number": 2,
      "title": "都 (dōu) — All / Both",
      "explanation": "都 means 'all' or 'both' and always comes before the verb, never before the subject. Formula: Subject(s) + 都 + Verb. It summarizes multiple subjects.",
      "examples": [
        {
          "chinese": "我们都是学生。",
          "pinyin": "Wǒmen dōu shì xuésheng.",
          "english": "We are all students."
        },
        {
          "chinese": "猫和狗都很可爱。",
          "pinyin": "Māo hé gǒu dōu hěn kě'ài.",
          "english": "Cats and dogs are both very cute."
        }
      ],
      "exercises": [
        {
          "question": "Say 'They all eat rice' in Chinese",
          "answer": "他们都吃米饭。",
          "type": "production"
        },
        {
          "question": "Where does 都 go in a sentence?",
          "answer": "Before the verb",
          "type": "concept"
        }
      ]
    },
    {
      "number": 3,
      "title": "怎么 (zěnme) — How",
      "explanation": "怎么 asks about the method or way of doing something. Formula: Subject + 怎么 + Verb? Compare: 怎么样 asks for a description; 怎么 asks for the method.",
      "examples": [
        {
          "chinese": "你怎么去？",
          "pinyin": "Nǐ zěnme qù?",
          "english": "How are you going?"
        },
        {
          "chinese": "这个字怎么写？",
          "pinyin": "Zhège zì zěnme xiě?",
          "english": "How do you write this character?"
        }
      ],
      "exercises": [
        {
          "question": "Ask 'How do you say this word?' in Chinese",
          "answer": "这个词怎么说？",
          "type": "production"
        },
        {
          "question": "Difference between 怎么 and 怎么样?",
          "answer": "怎么 = how (method); 怎么样 = how (description/opinion)",
          "type": "concept"
        }
      ]
    }
  ],
