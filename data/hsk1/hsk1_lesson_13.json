  "grammar_points": [
    {
      "number": 1,
      "title": "Demonstratives: 这, 那, 哪 (zhè, nà, nǎ)",
      "explanation": "这 = this (near); 那 = that (far); 哪 = which (question). Add 个 after them before nouns: 这个, 那个, 哪个. Add 儿 for locations: 这儿 (here), 那儿 (there), 哪儿 (where).",
      "examples": [
        {
          "chinese": "这个杯子很漂亮。",
          "pinyin": "Zhège bēizi hěn piàoliang.",
          "english": "This cup is very beautiful."
        },
        {
          "chinese": "哪个是你的？",
          "pinyin": "Nǎge shì nǐ de?",
          "english": "Which one is yours?"
        }
      ],
      "exercises": [
        {
          "question": "How do you say 'that chair'?",
          "answer": "那个椅子",
          "type": "production"
        },
        {
          "question": "What is the question form of 这 and 那?",
          "answer": "哪",
          "type": "concept"
        }
      ]
    },
    {
      "number": 2,
      "title": "Verb 住 (zhù) — To Live / Reside",
      "explanation": "住 means to live somewhere. Always followed by 在 + location. Formula: Subject + 住在 + Place. To ask where: 你住在哪儿？",
      "examples": [
        {
          "chinese": "我住在北京。",
          "pinyin": "Wǒ zhù zài Běijīng.",
          "english": "I live in Beijing."
        },
        {
          "chinese": "她住在学校旁边。",
          "pinyin": "Tā zhù zài xuéxiào pángbiān.",
          "english": "She lives next to the school."
        }
      ],
      "exercises": [
        {
          "question": "Ask 'Where does he live?' in Chinese",
          "answer": "他住在哪儿？",
          "type": "production"
        },
        {
          "question": "Fill in: 我___在上海。(I live in Shanghai)",
          "answer": "住",
          "type": "fill_in_blank"
        }
      ]
    },
    {
      "number": 3,
      "title": "Verb 开 (kāi) — To Open / Drive / Turn On",
      "explanation": "开 has several meanings: open a door (开门), drive a car (开车), turn on a device (开电脑/开电视). Context determines meaning.",
      "examples": [
        {
          "chinese": "请开门。",
          "pinyin": "Qǐng kāi mén.",
          "english": "Please open the door."
        },
        {
          "chinese": "我会开车。",
          "pinyin": "Wǒ huì kāi chē.",
          "english": "I can drive a car."
        }
      ],
      "exercises": [
        {
          "question": "How do you say 'turn on the TV'?",
          "answer": "开电视",
          "type": "production"
        },
        {
          "question": "What does 开 mean in 开车?",
          "answer": "To drive",
          "type": "concept"
        }
      ]
    }
  ],
