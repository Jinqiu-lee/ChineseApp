  "dialogues": [
    {
      "id": 1,
      "title": "Where Do You Live?",
      "title_chinese": "你住在哪儿",
      "lines": [
        { "speaker": "A", "chinese": "你住在哪儿？", "pinyin": "Nǐ zhù zài nǎr?", "english": "Where do you live?" },
        { "speaker": "B", "chinese": "我住在学校旁边。你呢？", "pinyin": "Wǒ zhù zài xuéxiào pángbiān. Nǐ ne?", "english": "I live next to the school. What about you?" },
        { "speaker": "A", "chinese": "我住在那儿，那个饭馆旁边。", "pinyin": "Wǒ zhù zài nàr, nàge fànguǎn pángbiān.", "english": "I live there, next to that restaurant." },
        { "speaker": "B", "chinese": "太好了！我们去那个饭馆吃饭吧！", "pinyin": "Tài hǎo le! Wǒmen qù nàge fànguǎn chīfàn ba!", "english": "Great! Let's go eat at that restaurant!" }
      ],
      "speakers": {
        "A": { "name": "小丽", "role": "同学", "gender": "female" },
        "B": { "name": "小明", "role": "同学", "gender": "male" }
      }
    },
    {
      "id": 2,
      "title": "What Is This?",
      "title_chinese": "这是什么",
      "lines": [
        { "speaker": "A", "chinese": "这是什么？", "pinyin": "Zhè shì shénme?", "english": "What is this?" },
        { "speaker": "B", "chinese": "这是我的电脑。", "pinyin": "Zhè shì wǒ de diànnǎo.", "english": "This is my computer." },
        { "speaker": "A", "chinese": "那个呢？那是桌子吗？", "pinyin": "Nàge ne? Nà shì zhuōzi ma?", "english": "What about that one? Is that a table?" },
        { "speaker": "B", "chinese": "是，那是桌子，桌子上有一个杯子。", "pinyin": "Shì, nà shì zhuōzi, zhuōzi shàng yǒu yīge bēizi.", "english": "Yes, that's a table. There's a cup on the table." }
      ],
      "speakers": {
        "A": { "name": "小华", "role": "朋友", "gender": "female" },
        "B": { "name": "大明", "role": "朋友", "gender": "male" }
      }
    },
