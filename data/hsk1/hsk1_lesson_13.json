        { "speaker": "B", "chinese": "谢谢。这椅子很舒服！", "pinyin": "Xièxie. Zhè yǐzi hěn shūfu!", "english": "Thank you. This chair is very comfortable!" },
        { "speaker": "A", "chinese": "我先开电脑，你喝茶吧。", "pinyin": "Wǒ xiān kāi diànnǎo, nǐ hē chá ba.", "english": "I'll turn on the computer first, have some tea." }
      ],
      "speakers": {
