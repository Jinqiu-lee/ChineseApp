  "grammar_points": [
    {
      "number": 1,
      "title": "Demonstratives: 这, 那, 哪 (zhè, nà, nǎ)",
      "explanation": "这 = this (near); 那 = that (far); 哪 = which (question). \n Add 个(gè) after them before nouns: 这个 - this(one), 那个 - that(one), 哪个 - which(one).\n \n Add 儿(er) for locations: 这儿(here), 那儿(there), 哪儿(where).",
      "examples": [
        {
          "chinese": "这个杯子很漂亮。",
          "pinyin": "Zhège bēizi hěn piàoliang.",
          "english": "This cup is very beautiful."
        },
        {
          "chinese": "哪个是你的？",
          "pinyin": "Nǎge shì nǐ de?",
          "english": "Which one is yours?"
        },
        {
          "chinese": "那儿有什么？",
          "pinyin": "Nǎr yǒu shénme?",
          "english": "What's (in) there?"
        }
