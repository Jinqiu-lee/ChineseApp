        { "speaker": "B", "chinese": "我想去那个，那个菜很好吃！", "pinyin": "Wǒ xiǎng qù nàge, nàge cài hěn hǎo chī!", "english": "I want to go to that one, the food there is delicious!" },
        { "speaker": "A", "chinese": "好！我们在那儿见面。", "pinyin": "Hǎo! Wǒmen zài nàr jiànmiàn.", "english": "Okay! Let's meet there." }
      ],
