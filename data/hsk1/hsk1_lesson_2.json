  "grammar_points": [
    {
      "number": 1,
      "title": "Chinese number system (1-99)",
      "explanation": "Numbers 1-10 are basic characters. 11-19: 十 + digit. 20-99: tens digit + 十 + ones digit.",
      "examples": [
        {
          "chinese": "十五",
          "pinyin": "shí wǔ",
          "english": "15"
        },
        {
          "chinese": "二十八",
          "pinyin": "èr shí bā",
          "english": "28"
        }
      ],
      "exercises": [
