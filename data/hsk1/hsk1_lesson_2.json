  "grammar_points": [
    {
      "number": 1,
      "title": "Chinese number system (1-99)",
      "explanation": "Numbers 1-10 are basic characters. 11-19: 十 + digit. 20-99: tens digit + 十 + ones digit.",
      "examples": [
        {
          "chinese": "十五",
          "pinyin": "shí wǔ",
          "english": "15"
        },
        {
          "chinese": "二十八",
          "pinyin": "èr shí bā",
          "english": "28"
        }
      ],
      "exercises": [
        {
          "question": "How do you say '17' in Chinese?",
          "type": "multiple_choice",
          "correct": "十七",
          "options": [
            "七十",
            "十七",
            "一七",
            "七一"
          ]
        },
        {
          "question": "What number is 三十四?",
          "type": "multiple_choice",
          "correct": "34",
          "options": [
            "34",
            "43",
            "13",
            "31"
          ]
        },
        {
          "question": "How do you write 'twenty' in Chinese?",
          "type": "multiple_choice",
          "correct": "二十",
          "options": [
            "二十",
            "十二",
            "二",
            "二零"
          ]
        }
      ]
    },
    {
      "number": 2,
      "title": "Measure word 个 (gè)",
      "explanation": "个 (gè) is used between a number and a noun. Formula: Number + 个 + Noun.",
      "examples": [
        {
          "chinese": "一个人",
          "pinyin": "yī gè rén",
          "english": "One person"
        },
        {
          "chinese": "三个朋友",
          "pinyin": "sān gè péng yǒu",
          "english": "Three friends"
        }
      ],
      "exercises": [
        {
          "question": "Fill in: 两___人 (two people)",
          "type": "multiple_choice",
          "correct": "个",
          "options": [
            "个",
            "本",
            "杯",
            "口"
          ]
        },
        {
          "question": "How do you say 'five students'?",
          "type": "multiple_choice",
          "correct": "五个学生",
          "options": [
            "五个学生",
            "个五学生",
            "五学生",
            "学生五个"
          ]
        },
        {
          "question": "What goes between number and noun?",
          "type": "multiple_choice",
          "correct": "measure word",
          "options": [
            "measure word",
            "verb",
            "的",
            "是"
          ]
        }
      ]
    },
    {
      "number": 3,
      "title": "Asking age with 多大 (duō dà)",
      "explanation": "多大 means 'how big' but is used to ask age. Answer with number + 岁.",
      "examples": [
        {
          "chinese": "你多大？我十八岁。",
          "pinyin": "Nǐ duō dà? Wǒ shí bā suì.",
          "english": "How old are you? I'm 18."
        }
      ],
      "exercises": [
        {
          "question": "How do you ask 'How old are you?'",
          "type": "multiple_choice",
          "correct": "你多大？",
          "options": [
            "你多大？",
            "你几岁？",
            "你有多少？",
            "你是多大？"
          ]
        },
        {
          "question": "How do you say 'I am 22 years old'?",
          "type": "multiple_choice",
          "correct": "我二十二岁。",
          "options": [
            "我二十二岁。",
            "我是二十二。",
            "我有二十二岁。",
            "二十二岁我。"
          ]
        },
        {
          "question": "What word means 'years old'?",
          "type": "multiple_choice",
          "correct": "岁",
          "options": [
            "岁",
            "年",
            "月",
            "号"
          ]
        }
      ]
    }
  ],
