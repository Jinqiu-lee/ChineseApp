  "grammar_points": [
    {
      "number": 1,
      "title": "Using 想 (xiǎng) - To want / Would like",
      "explanation": "想 (xiǎng) expresses desire or intention. It's followed directly by a verb (no 'to'). Formula: Subject + 想 + Verb + Object. 想 is softer and more polite than 要.",
      "examples": [
        {
          "chinese": "我想吃面条。",
          "pinyin": "Wǒ xiǎng chī miàn tiáo.",
          "english": "I want to eat noodles."
        },
        {
          "chinese": "她想喝咖啡。",
          "pinyin": "Tā xiǎng hē kā fēi.",
          "english": "She wants to drink coffee."
        }
      ],
      "exercises": [
        {
          "question": "Say 'I want to eat rice' in Chinese",
          "answer": "我想吃米饭。",
          "type": "production"
        },
        {
          "question": "Fill in: 他___喝茶。(He wants to drink tea)",
          "answer": "想",
          "type": "fill_in_blank"
        },
        {
          "question": "Translate: Do you want to eat apples?",
          "answer": "你想吃苹果吗？",
          "type": "translation"
        },
        {
          "question": "What comes after 想 in a sentence?",
          "answer": "verb (action word)",
          "type": "concept"
        }
      ]
    },
    {
      "number": 2,
      "title": "Measure word 杯 (bēi) for beverages",
      "explanation": "杯 (bēi) means 'cup' or 'glass' and is used as a measure word for drinks. Formula: Number + 杯 + Beverage. It's similar to saying 'a cup of' in English.",
      "examples": [
        {
          "chinese": "两杯茶",
          "pinyin": "liǎng bēi chá",
          "english": "Two cups of tea"
        },
        {
          "chinese": "一杯水",
          "pinyin": "yī bēi shuǐ",
          "english": "A glass of water"
        }
      ],
      "exercises": [
        {
          "question": "Say 'three cups of coffee' in Chinese",
          "answer": "三杯咖啡",
          "type": "production"
        },
        {
          "question": "Fill in: 一___牛奶 (one glass of milk)",
          "answer": "杯",
          "type": "fill_in_blank"
        },
        {
          "question": "What measure word is used for beverages?",
          "answer": "杯",
          "type": "concept"
        },
        {
          "question": "Translate: Two glasses of water",
          "answer": "两杯水",
          "type": "translation"
        }
      ]
    },
    {
      "number": 3,
      "title": "Asking 'what' with 什么 (shén me)",
      "explanation": "什么 (shén me) means 'what' and is used to ask questions. It replaces the thing you're asking about in the sentence. Formula: Subject + Verb + 什么？ Position matters!",
      "examples": [
        {
          "chinese": "你吃什么？",
          "pinyin": "Nǐ chī shén me?",
          "english": "What do you eat?"
        },
        {
          "chinese": "这是什么？",
          "pinyin": "Zhè shì shén me?",
          "english": "What is this?"
        }
      ],
      "exercises": [
        {
          "question": "Ask 'What do you drink?' in Chinese",
          "answer": "你喝什么？",
          "type": "production"
        },
        {
          "question": "Ask 'What does she want?' using 想",
          "answer": "她想什么？",
          "type": "production"
        },
        {
          "question": "Where does 什么 go in 'What is your name?'",
          "answer": "你叫什么名字？",
          "type": "production"
        }
      ]
    }
  ],
