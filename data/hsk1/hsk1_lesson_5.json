  "grammar_points": [
    {
      "number": 1,
      "title": "Using 想 (xiǎng) - To want / Would like",
      "explanation": "想(xiǎng) expresses desire or intention. It's followed directly by a verb. Formula: Subject + 想(xiǎng) + Verb + Object. 想(xiǎng) is softer and more polite than 要(yào).",
      "examples": [
        {
          "chinese": "我想吃面条。",
          "pinyin": "Wǒ xiǎng chī miàn tiáo.",
          "english": "I want to eat noodles."
        },
        {
          "chinese": "她想喝咖啡。",
          "pinyin": "Tā xiǎng hē kā fēi.",
          "english": "She wants to drink coffee."
        }
      ],
