  "grammar_points": [
    {
      "number": 1,
      "title": "Asking price with 多少钱 (duō shǎo qián)",
      "explanation": "多少钱 means 'how much money' and is used to ask prices. Formula: This/That + (Measure word) + Item + 多少钱？ Always put 多少钱 at the end of the question.",
      "examples": [
        {
          "chinese": "这个苹果多少钱？",
          "pinyin": "Zhè ge píng guǒ duō shǎo qián?",
          "english": "How much is this apple?"
        },
        {
          "chinese": "那本书多少钱？",
          "pinyin": "Nà běn shū duō shǎo qián?",
          "english": "How much is that book?"
        }
      ],
      "exercises": [
        {
          "question": "Ask 'How much is this?' in Chinese",
          "answer": "这个多少钱？",
          "type": "production"
        },
        {
          "question": "Ask the price of 'that coffee'",
          "answer": "那杯咖啡多少钱？",
          "type": "production"
        },
        {
          "question": "Where does 多少钱 go in a price question?",
          "answer": "at the end",
          "type": "concept"
        },
        {
          "question": "Translate: How much is this clothing?",
          "answer": "这件衣服多少钱？",
          "type": "translation"
        }
      ]
    },
    {
      "number": 2,
      "title": "Currency: 块 (kuài) for yuan",
      "explanation": "块 (kuài) is the colloquial word for 元 (yuán), the Chinese currency unit (RMB). It's like saying 'bucks' instead of 'dollars'. Formula: Number + 块 (+ 钱).",
      "examples": [
        {
          "chinese": "三十块",
          "pinyin": "sān shí kuài",
          "english": "30 yuan"
        },
        {
          "chinese": "一百块钱",
          "pinyin": "yī bǎi kuài qián",
          "english": "100 yuan"
        }
      ],
      "exercises": [
        {
          "question": "Say '25 yuan' in Chinese",
          "answer": "二十五块",
          "type": "production"
        },
        {
          "question": "What does 块 mean in pricing?",
          "answer": "yuan / RMB",
          "type": "concept"
        },
        {
          "question": "Say '50 yuan' in Chinese",
          "answer": "五十块",
          "type": "production"
        },
        {
          "question": "Is 块 formal or colloquial?",
          "answer": "colloquial",
          "type": "concept"
        }
      ]
    },
    {
      "number": 3,
      "title": "Measure word 本 (běn) for books",
      "explanation": "本 (běn) is the measure word specifically for books, magazines, and bound printed materials. Formula: Number + 本 + Book/Magazine. Different items need different measure words.",
      "examples": [
        {
          "chinese": "一本书",
          "pinyin": "yī běn shū",
          "english": "One book"
        },
        {
          "chinese": "三本杂志",
          "pinyin": "sān běn zá zhì",
          "english": "Three magazines"
        }
      ],
      "exercises": [
        {
          "question": "Say 'two books' in Chinese",
          "answer": "两本书",
          "type": "production"
        },
        {
          "question": "What measure word is used for books?",
          "answer": "本",
          "type": "concept"
        },
        {
          "question": "Fill in: 五___书 (five books)",
          "answer": "本",
          "type": "fill_in_blank"
        },
        {
          "question": "Translate: This book",
          "answer": "这本书",
          "type": "translation"
        }
      ]
    }
