  "grammar_points": [
    {
      "number": 1,
      "title": "怎么样 (zěnmeyàng) — How / What's it like",
      "explanation": "怎么样 asks for a description or opinion. Formula: Subject + 怎么样? It can also follow a topic: 天气怎么样? (How is the weather?). More open-ended than yes/no 吗 questions.",
      "examples": [
        {
          "chinese": "天气怎么样？",
          "pinyin": "Tiānqì zěnmeyàng?",
          "english": "How's the weather?"
        },
        {
          "chinese": "你怎么样？",
          "pinyin": "Nǐ zěnmeyàng?",
          "english": "How are you?"
        }
      ],
      "exercises": [
        {
          "question": "Ask 'How is the food?' in Chinese",
          "answer": "菜怎么样？",
          "type": "production"
        },
        {
          "question": "Fill in: 今天天气___？(How's the weather today?)",
          "answer": "怎么样",
          "type": "fill_in_blank"
        }
      ]
    },
    {
      "number": 2,
      "title": "太...了 (tài...le) — Too / Excessively",
      "explanation": "太 + Adjective + 了 expresses excess. 太 alone without 了 can mean 'very' in casual speech, but 太...了 emphasizes too much. Formula: Subject + 太 + Adjective + 了.",
      "examples": [
        {
          "chinese": "今天太热了！",
          "pinyin": "Jīntiān tài rè le!",
          "english": "It's too hot today!"
        },
        {
          "chinese": "这个太大了。",
          "pinyin": "Zhège tài dà le.",
          "english": "This is too big."
        }
      ],
      "exercises": [
        {
          "question": "Say 'The coffee is too hot' using 太...了",
          "answer": "咖啡太热了。",
          "type": "production"
        },
        {
          "question": "Fill in: 今天___冷___！(It's too cold today)",
          "answer": "太 / 了",
          "type": "fill_in_blank"
        }
      ]
    },
    {
      "number": 3,
      "title": "和 (hé) — And (connecting nouns)",
      "explanation": "和 connects two nouns or pronouns. It cannot connect verbs or sentences (unlike English 'and'). Formula: Noun A + 和 + Noun B. Example: 你和我 (you and I).",
      "examples": [
        {
          "chinese": "你和我都是学生。",
          "pinyin": "Nǐ hé wǒ dōu shì xuésheng.",
          "english": "You and I are both students."
        },
        {
          "chinese": "茶和咖啡",
          "pinyin": "chá hé kāfēi",
          "english": "Tea and coffee"
        }
      ],
      "exercises": [
        {
          "question": "Say 'rice and noodles' in Chinese",
          "answer": "米饭和面条",
          "type": "production"
        },
        {
          "question": "Can 和 connect two verbs?",
          "answer": "No, 和 only connects nouns/pronouns",
          "type": "concept"
        }
      ]
    }
  ],
