  "grammar_points": [
    {
      "number": 1,
      "title": "怎么样 (zěnmeyàng) — How / What's it like",
      "explanation": "怎么样(zěnmeyàng) asks for a description or opinion. It can also follow a topic: 天气怎么样(tiānqì zěnmeyàng)? --- (How is the weather?). More open-ended than yes/no 吗(ma) questions. Formula: Subject + 怎么样(zěnmeyàng)? ",
      "examples": [
        {
          "chinese": "天气怎么样？",
          "pinyin": "Tiānqì zěnmeyàng?",
          "english": "How's the weather?"
        },
        {
          "chinese": "你怎么样？",
          "pinyin": "Nǐ zěnmeyàng?",
          "english": "How are you?"
        }
      ],
