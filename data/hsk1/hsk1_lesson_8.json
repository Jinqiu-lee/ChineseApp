  "grammar_points": [
    {
      "number": 1,
      "title": "Using 去 (qù) - To go to a place",
      "explanation": "去 (qù) means 'to go' and is followed by a location. Formula: Subject + 去 + Place. To ask where someone is going: Subject + 去 + 哪儿？",
      "examples": [
        {
          "chinese": "我去医院。",
          "pinyin": "Wǒ qù yī yuàn.",
          "english": "I'm going to the hospital."
        },
        {
          "chinese": "他们去商店。",
          "pinyin": "Tā men qù shāng diàn.",
          "english": "They're going to the store."
        }
      ],
      "exercises": [
        {
          "question": "Say 'I'm going to school' in Chinese",
          "answer": "我去学校。",
          "type": "production"
        },
        {
          "question": "Ask 'Where are you going?'",
          "answer": "你去哪儿？",
          "type": "production"
        },
        {
          "question": "Fill in: 她___家。(She's going home)",
          "answer": "去",
          "type": "fill_in_blank"
        },
        {
          "question": "Translate: He's going to the hospital",
          "answer": "他去医院。",
          "type": "translation"
        }
      ]
    },
    {
      "number": 2,
      "title": "Using 看 (kàn) - To watch/read/look",
      "explanation": "看 (kàn) has multiple meanings depending on context: to watch (TV/movies), to read (books/newspapers), or to look at. Formula: Subject + 看 + Object.",
      "examples": [
        {
          "chinese": "我看电影。",
          "pinyin": "Wǒ kàn diàn yǐng.",
          "english": "I watch movies."
        },
        {
          "chinese": "他看书。",
          "pinyin": "Tā kàn shū.",
          "english": "He reads books."
        }
      ],
      "exercises": [
        {
          "question": "Say 'I watch TV' in Chinese",
          "answer": "我看电视。",
          "type": "production"
        },
        {
          "question": "What does 看 mean with 书?",
          "answer": "to read (books)",
          "type": "concept"
        },
        {
          "question": "Translate: She watches movies",
          "answer": "她看电影。",
          "type": "translation"
        },
        {
          "question": "Does 看 mean the same thing in all contexts? (Yes/No)",
          "answer": "No",
          "type": "concept"
        }
      ]
    },
    {
      "number": 3,
      "title": "Ongoing action with 在 (zài) + Verb",
      "explanation": "在 + Verb shows an action currently in progress (similar to '-ing' in English). Formula: Subject + 在 + Verb + Object. This is different from 在 for location.",
      "examples": [
        {
          "chinese": "我在吃饭。",
          "pinyin": "Wǒ zài chī fàn.",
          "english": "I am eating."
        },
        {
          "chinese": "他在看书。",
          "pinyin": "Tā zài kàn shū.",
          "english": "He is reading."
        }
      ],
      "exercises": [
        {
          "question": "Say 'I am writing' in Chinese",
          "answer": "我在写。",
          "type": "production"
        },
        {
          "question": "What does 在 + verb indicate?",
          "answer": "ongoing/current action",
          "type": "concept"
        },
        {
          "question": "Translate: She is working",
          "answer": "她在工作。",
          "type": "translation"
        },
        {
          "question": "Make progressive: 他看电视。",
          "answer": "他在看电视。",
          "type": "transformation"
        }
      ]
    }
  ],
