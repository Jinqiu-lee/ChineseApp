  "grammar_points": [
    {
      "number": 1,
      "title": "Date expressions: Year-Month-Date order",
      "explanation": "Chinese dates go from largest to smallest unit: 年(year) → 月(month) → 号(date). This is opposite to British English (15 March 2024) and different from American English (March 15, 2024). Formula: [Year]年 + [Month]月 + [Date]号",
      "examples": [
        {
          "chinese": "2024年6月1号",
          "pinyin": "Èr líng èr sì nián liù yuè yí hào",
          "english": "June 1, 2024"
        },
        {
          "chinese": "2025年12月31号",
          "pinyin": "Èr líng èr wǔ nián shí èr yuè sān shí yí hào",
          "english": "December 31, 2025"
        }
      ],
      "exercises": [
        {
          "question": "Translate to Chinese: 'March 5, 2025'",
          "answer": "2025年3月5号",
          "type": "translation"
        },
        {
          "question": "Write the correct order: [号, 月, 年]",
          "answer": "年, 月, 号",
          "type": "ordering"
        },
        {
          "question": "Say the date: 2024年10月20号",
          "answer": "èr líng èr sì nián shí yuè èr shí hào",
          "type": "pinyin_production"
        },
        {
          "question": "What comes first in Chinese dates: month or year?",
          "answer": "year (年)",
          "type": "concept"
        }
      ]
    },
    {
      "number": 2,
      "title": "Time expressions with 点 (diǎn) and 分 (fēn)",
      "explanation": "点 means 'o'clock' and 分 means 'minute'. Time format: [Time of day] + [Hour]点 + [Minutes]分. Time of day comes first: 上午/下午/晚上. Use 半 (bàn) for 'half past'.",
      "examples": [
        {
          "chinese": "上午十点二十分",
          "pinyin": "Shàng wǔ shí diǎn èr shí fēn",
          "english": "10:20 AM"
        },
        {
          "chinese": "晚上七点半",
          "pinyin": "Wǎn shang qī diǎn bàn",
          "english": "7:30 PM"
        }
      ],
      "exercises": [
        {
          "question": "Say '3:15 PM' in Chinese",
          "answer": "下午三点十五分",
          "type": "production"
        },
        {
          "question": "What does 点 mean in time expressions?",
          "answer": "o'clock",
          "type": "concept"
        },
        {
          "question": "Translate: 9:30 AM",
          "answer": "上午九点半 or 上午九点三十分",
          "type": "translation"
        },
        {
          "question": "Which comes first: time of day or hour?",
          "answer": "time of day (上午/下午/晚上)",
          "type": "concept"
        }
      ]
    },
    {
      "number": 3,
      "title": "Time words: 今天, 明天, 昨天",
      "explanation": "These three words describe days relative to today. 今天 (jīn tiān) = today, 明天 (míng tiān) = tomorrow, 昨天 (zuó tiān) = yesterday. They can be used alone or with dates/times.",
      "examples": [
        {
          "chinese": "今天是星期一。",
          "pinyin": "Jīn tiān shì xīng qī yī.",
          "english": "Today is Monday."
        },
        {
          "chinese": "明天几号？",
          "pinyin": "Míng tiān jǐ hào?",
          "english": "What's the date tomorrow?"
        }
      ],
      "exercises": [
        {
          "question": "How do you say 'yesterday' in Chinese?",
          "answer": "昨天",
          "type": "production"
        },
        {
          "question": "Ask 'What is today's date?'",
          "answer": "今天几号？",
          "type": "production"
        },
        {
          "question": "Translate: Tomorrow is March 10th",
          "answer": "明天是三月十号。",
          "type": "translation"
        }
      ]
    }
  ],
