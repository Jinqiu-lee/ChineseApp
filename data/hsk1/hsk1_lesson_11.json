  "dialogues": [
    {
      "id": 1,
      "title": "What Time Is It Now?",
      "title_chinese": "现在几点",
      "lines": [
        { "speaker": "A", "chinese": "请问，现在几点？", "pinyin": "Qǐngwèn, xiànzài jǐ diǎn?", "english": "Excuse me, what time is it now?" },
        { "speaker": "B", "chinese": "现在下午两点半。", "pinyin": "Xiànzài xiàwǔ liǎng diǎn bàn.", "english": "It's 2:30 PM now." },
        { "speaker": "A", "chinese": "谢谢！", "pinyin": "Xièxie!", "english": "Thank you!" },
        { "speaker": "B", "chinese": "不客气。", "pinyin": "Bú kèqi.", "english": "You're welcome." }
      ],
      "speakers": {
        "A": { "name": "小丽", "role": "学生", "gender": "female" },
        "B": { "name": "王先生", "role": "路人", "gender": "male" }
      }
    },
    {
      "id": 2,
      "title": "Phone Call",
      "title_chinese": "打电话",
      "lines": [
        { "speaker": "A", "chinese": "喂，你好！", "pinyin": "Wèi, nǐ hǎo!", "english": "Hello!" },
        { "speaker": "B", "chinese": "你好！现在几点了？", "pinyin": "Nǐ hǎo! Xiànzài jǐ diǎn le?", "english": "Hello! What time is it now?" },
        { "speaker": "A", "chinese": "现在上午九点。你什么时候来？", "pinyin": "Xiànzài shàngwǔ jiǔ diǎn. Nǐ shénme shíhou lái?", "english": "It's 9 AM now. When are you coming?" },
        { "speaker": "B", "chinese": "我十分钟后来。", "pinyin": "Wǒ shí fēnzhōng hòu lái.", "english": "I'll come in ten minutes." }
      ],
      "speakers": {
        "A": { "name": "小华", "role": "朋友", "gender": "female" },
        "B": { "name": "小明", "role": "朋友", "gender": "male" }
      }
    },
