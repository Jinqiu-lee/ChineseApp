        { "speaker": "A", "chinese": "你星期六有空吗？", "pinyin": "Nǐ xīngqīliù yǒu kòng ma?", "english": "Are you free on Saturday?" },
        { "speaker": "B", "chinese": "有。我们中午一起吃饭吧！", "pinyin": "Yǒu. Wǒmen zhōngwǔ yīqǐ chīfàn ba!", "english": "Yes. Let's have lunch together!" }
      ],
