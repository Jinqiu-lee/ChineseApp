  "grammar_points": [
    {
      "number": 1,
      "title": "Telling Clock Time: X点Y分",
      "explanation": "To tell clock time: [Time of day] + [Number] + 点 + [Minutes] + 分. Minutes are optional if on the hour. 半 (bàn) = half past. Examples: 三点 (3:00), 三点半 (3:30), 三点十分 (3:10).",
      "examples": [
        { "chinese": "现在下午三点半。", "pinyin": "Xiànzài xiàwǔ sān diǎn bàn.", "english": "It's 3:30 PM now." },
        { "chinese": "我上午九点来。", "pinyin": "Wǒ shàngwǔ jiǔ diǎn lái.", "english": "I'll come at 9 AM." }
      ],
      "exercises": [
        { "question": "How do you say '7:00 PM'?", "answer": "晚上七点", "type": "production" },
        { "question": "Fill in: 现在中午___点。(It is now 12:00 noon)", "answer": "十二", "type": "fill_in_blank" }
      ]
    },
    {
      "number": 2,
      "title": "什么时候 (shénme shíhou) — When",
      "explanation": "什么时候 asks about when something happens. It is placed before the verb, like all time expressions in Chinese. Formula: Subject + 什么时候 + Verb?",
      "examples": [
        { "chinese": "你什么时候去中国？", "pinyin": "Nǐ shénme shíhou qù Zhōngguó?", "english": "When are you going to China?" },
        { "chinese": "你什么时候吃饭？", "pinyin": "Nǐ shénme shíhou chīfàn?", "english": "When do you eat?" }
      ],
      "exercises": [
        { "question": "Ask 'When does she come?' in Chinese", "answer": "她什么时候来？", "type": "production" },
        { "question": "Where does 什么时候 go in the sentence?", "answer": "Before the verb", "type": "concept" }
      ]
    },
    {
      "number": 3,
      "title": "Days of the Week: 星期 + Number",
      "explanation": "星期 + 1-6 = Monday to Saturday. 星期天/日 = Sunday. 星期几? = What day of the week? Numbers 1-6 go after 星期.",
      "examples": [
        { "chinese": "今天星期一。", "pinyin": "Jīntiān xīngqīyī.", "english": "Today is Monday." },
        { "chinese": "星期天我在家。", "pinyin": "Xīngqītiān wǒ zài jiā.", "english": "I'm at home on Sunday." }
      ],
      "exercises": [
        { "question": "How do you say 'Friday'?", "answer": "星期五", "type": "production" },
        { "question": "What does 星期天 mean?", "answer": "Sunday", "type": "concept" }
      ]
    }
  ],
