  "dialogues": [
    {
      "id": 1,
      "title": "Nice to Meet You",
      "title_chinese": "认识你很高兴",
      "lines": [
        { "speaker": "A", "chinese": "你好！我叫小丽。", "pinyin": "Nǐ hǎo! Wǒ jiào Xiǎo Lì.", "english": "Hello! My name is Xiao Li." },
        { "speaker": "B", "chinese": "你好！我叫大明。认识你很高兴！", "pinyin": "Nǐ hǎo! Wǒ jiào Dà Míng. Rènshi nǐ hěn gāoxìng!", "english": "Hello! I'm Da Ming. Nice to meet you!" },
        { "speaker": "A", "chinese": "我也很高兴！你是学生吗？", "pinyin": "Wǒ yě hěn gāoxìng! Nǐ shì xuésheng ma?", "english": "I'm glad too! Are you a student?" },
        { "speaker": "B", "chinese": "是，我是学生。我们是同学！", "pinyin": "Shì, wǒ shì xuésheng. Wǒmen shì tóngxué!", "english": "Yes, I'm a student. We are classmates!" }
      ],
      "speakers": {
        "A": { "name": "小丽", "role": "学生", "gender": "female" },
        "B": { "name": "大明", "role": "学生", "gender": "male" }
      }
    },
    {
      "id": 2,
      "title": "Can You Speak Chinese?",
      "title_chinese": "你会说汉语吗",
      "lines": [
        { "speaker": "A", "chinese": "你会说汉语吗？", "pinyin": "Nǐ huì shuō Hànyǔ ma?", "english": "Can you speak Chinese?" },
        { "speaker": "B", "chinese": "会，我会说一点汉语。你呢？", "pinyin": "Huì, wǒ huì shuō yīdiǎn Hànyǔ. Nǐ ne?", "english": "Yes, I can speak a little Chinese. What about you?" },
        { "speaker": "A", "chinese": "我也会说汉语。我们一起学习！", "pinyin": "Wǒ yě huì shuō Hànyǔ. Wǒmen yīqǐ xuéxí!", "english": "I can speak Chinese too. Let's study together!" }
      ],
      "speakers": {
        "A": { "name": "小华", "role": "老师", "gender": "female" },
        "B": { "name": "小明", "role": "学生", "gender": "male" }
      }
    },
    {
      "id": 3,
      "title": "Are You from China?",
      "title_chinese": "你是中国人吗",
      "lines": [
        { "speaker": "A", "chinese": "你好！你是中国人吗？", "pinyin": "Nǐ hǎo! Nǐ shì Zhōngguórén ma?", "english": "Hello! Are you Chinese?" },
        { "speaker": "B", "chinese": "是，我是中国人。你呢？", "pinyin": "Shì, wǒ shì Zhōngguórén. Nǐ ne?", "english": "Yes, I'm Chinese. What about you?" },
        { "speaker": "A", "chinese": "我不是，但是我想学汉语。", "pinyin": "Wǒ bù shì, dànshì wǒ xiǎng xué Hànyǔ.", "english": "I'm not, but I want to study Chinese." },
        { "speaker": "B", "chinese": "好！我们一起学习，好朋友！", "pinyin": "Hǎo! Wǒmen yīqǐ xuéxí, hǎo péngyou!", "english": "Great! Let's study together, good friend!" }
      ],
      "speakers": {
        "A": { "name": "小美", "role": "朋友", "gender": "female" },
        "B": { "name": "小刚", "role": "朋友", "gender": "male" }
      }
    },
    {
