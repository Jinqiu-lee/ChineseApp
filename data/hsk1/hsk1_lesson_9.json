  "grammar_points": [
    {
      "number": 1,
      "title": "Modal Verb 会 (huì) — Learned Ability",
      "explanation": "会(huì) expresses a skill or ability acquired through learning. Formula: Subject + 会(huì) + Verb; Negative: Subject + 不会(bú huì) + Verb . It differs from 能(physical ability/permission). 会(huì) = learned skill, like speaking a language.",
      "examples": [
        {
          "chinese": "我会说汉语。",
          "pinyin": "Wǒ huì shuō Hànyǔ.",
          "english": "I can speak Chinese."
        },
        {
          "chinese": "她会唱歌。",
          "pinyin": "Tā huì chàng gē.",
          "english": "She can sing."
        },
        {
          "chinese": "我不会做饭。",
          "pinyin": "Wǒ bú huì zuò fàn.",
          "english": "I don't know how to cook."
        }
      ],
