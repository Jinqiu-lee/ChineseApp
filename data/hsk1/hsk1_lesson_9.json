  "grammar_points": [
    {
      "number": 1,
      "title": "Modal Verb 会 (huì) — Learned Ability",
      "explanation": "会 expresses a skill or ability acquired through learning. Formula: Subject + 会 + Verb. It differs from 能 (physical ability/permission). 会 = learned skill, like speaking a language.",
      "examples": [
        {
          "chinese": "我会说汉语。",
          "pinyin": "Wǒ huì shuō Hànyǔ.",
          "english": "I can speak Chinese."
        },
        {
          "chinese": "她会唱歌。",
          "pinyin": "Tā huì chàng gē.",
          "english": "She can sing."
        }
      ],
      "exercises": [
        {
          "question": "Say 'He can speak Chinese' using 会",
          "answer": "他会说汉语。",
          "type": "production"
        },
        {
          "question": "Fill in: 你___说汉语吗？",
          "answer": "会",
          "type": "fill_in_blank"
        },
        {
          "question": "Translate: Can you read Chinese?",
          "answer": "你会读汉语吗？",
          "type": "translation"
        }
      ]
    },
    {
      "number": 2,
      "title": "Plural Pronoun 我们 (wǒmen) — We / Us",
      "explanation": "Add 们 to a pronoun to make it plural. 我→我们 (I→we), 你→你们 (you→you all), 他/她→他们/她们 (he/she→they). 们 cannot be added to nouns.",
      "examples": [
        {
          "chinese": "我们是朋友。",
          "pinyin": "Wǒmen shì péngyou.",
          "english": "We are friends."
        },
        {
          "chinese": "你们好！",
          "pinyin": "Nǐmen hǎo!",
          "english": "Hello everyone!"
        }
      ],
      "exercises": [
        {
          "question": "How do you say 'they' (male) in Chinese?",
          "answer": "他们",
          "type": "concept"
        },
        {
          "question": "Fill in: ___是同学。(We are classmates)",
          "answer": "我们",
          "type": "fill_in_blank"
        }
      ]
    },
    {
      "number": 3,
      "title": "Polite Expressions: 对不起 and 不客气",
      "explanation": "对不起 (duìbuqǐ) = Sorry/Excuse me. Common response: 没关系 (méi guānxi) = It doesn't matter. 不客气 (bú kèqi) = You're welcome. Used after someone thanks you (谢谢).",
      "examples": [
        {
          "chinese": "对不起！没关系。",
          "pinyin": "Duìbuqǐ! Méi guānxi.",
          "english": "Sorry! It's okay."
        },
        {
          "chinese": "谢谢！不客气。",
          "pinyin": "Xièxie! Bú kèqi.",
          "english": "Thank you! You're welcome."
        }
      ],
      "exercises": [
        {
          "question": "What do you say after 谢谢？",
          "answer": "不客气",
          "type": "concept"
        },
        {
          "question": "What is the response to 对不起？",
          "answer": "没关系",
          "type": "concept"
        }
      ]
    }
  ],
