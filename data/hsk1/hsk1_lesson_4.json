  "grammar_points": [
    {
      "number": 1,
      "title": "Using 有 (yǒu) - To have / There is",
      "explanation": "有 (yǒu) means 'to have' or 'there is/are'. It shows possession or existence. Formula: Subject + 有 + Object. For family members, 的 is often omitted.",
      "examples": [
        {
          "chinese": "我有一个哥哥。",
          "pinyin": "Wǒ yǒu yī gè gē ge.",
          "english": "I have an older brother."
        },
        {
          "chinese": "他有三本书。",
          "pinyin": "Tā yǒu sān běn shū.",
          "english": "He has three books."
        }
      ],
      "exercises": [
        {
          "question": "Say 'I have two sisters' in Chinese",
          "answer": "我有两个姐姐。or 我有两个妹妹。",
          "type": "production"
        },
        {
          "question": "Fill in: 她___一个弟弟。(She has a younger brother)",
          "answer": "有",
          "type": "fill_in_blank"
        },
        {
          "question": "Translate: Do you have a dog?",
          "answer": "你有狗吗？",
          "type": "translation"
        },
        {
          "question": "What verb means 'to have' in Chinese?",
          "answer": "有",
          "type": "concept"
        }
      ]
    },
    {
      "number": 2,
      "title": "Negation with 没有 (méi yǒu)",
      "explanation": "To negate 有, use 没有 (méi yǒu), NOT 不. 没有 means 'don't have' or 'there isn't'. Formula: Subject + 没有 + Object. Note: 不 cannot be used with 有.",
      "examples": [
        {
          "chinese": "我没有妹妹。",
          "pinyin": "Wǒ méi yǒu mèi mei.",
          "english": "I don't have a younger sister."
        },
        {
          "chinese": "他没有钱。",
          "pinyin": "Tā méi yǒu qián.",
          "english": "He doesn't have money."
        }
      ],
      "exercises": [
        {
          "question": "Say 'I don't have an older brother' in Chinese",
          "answer": "我没有哥哥。",
          "type": "production"
        },
        {
          "question": "How do you negate the verb 有?",
          "answer": "没有",
          "type": "concept"
        },
        {
          "question": "Negate this sentence: 她有弟弟。",
          "answer": "她没有弟弟。",
          "type": "transformation"
        },
        {
          "question": "Can you use 不 to negate 有? (Yes/No)",
          "answer": "No",
          "type": "concept"
        }
      ]
    },
    {
      "number": 3,
      "title": "Measure word 口 (kǒu) for family members",
      "explanation": "口 (kǒu) literally means 'mouth' but is the special measure word for counting family members. Formula: Number + 口 + 人. Use when asking 'How many people in your family?'",
      "examples": [
        {
          "chinese": "我家有五口人。",
          "pinyin": "Wǒ jiā yǒu wǔ kǒu rén.",
          "english": "There are five people in my family."
        },
        {
          "chinese": "你家有几口人？",
          "pinyin": "Nǐ jiā yǒu jǐ kǒu rén?",
          "english": "How many people are in your family?"
        }
      ],
      "exercises": [
        {
          "question": "Ask 'How many people in your family?' in Chinese",
          "answer": "你家有几口人？",
          "type": "production"
        },
        {
          "question": "Say 'There are 3 people in my family'",
          "answer": "我家有三口人。",
          "type": "production"
        },
        {
          "question": "What measure word is used for family members?",
          "answer": "口",
          "type": "concept"
        }
      ]
    }
  ],
