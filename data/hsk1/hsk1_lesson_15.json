  "key_sentences": [
    { "chinese": "你怎么去？", "pinyin": "Nǐ zěnme qù?", "english": "How are you getting there?" },
    { "chinese": "我是坐飞机来的。", "pinyin": "Wǒ shì zuò fēijī lái de.", "english": "I came by airplane." },
    { "chinese": "机场远不远？", "pinyin": "Jīchǎng yuǎn bù yuǎn?", "english": "Is the airport far?" },
    { "chinese": "坐地铁去吧。", "pinyin": "Zuò dìtiě qù ba.", "english": "Take the subway." },
    { "chinese": "买票多少钱？", "pinyin": "Mǎi piào duōshǎo qián?", "english": "How much is the ticket?" }
