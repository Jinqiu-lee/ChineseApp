  "dialogues": [
    {
      "id": 1,
      "title": "How Did You Get Here?",
      "title_chinese": "你怎么来的",
      "lines": [
        { "speaker": "A", "chinese": "你是怎么来中国的？", "pinyin": "Nǐ shì zěnme lái Zhōngguó de?", "english": "How did you come to China?" },
        { "speaker": "B", "chinese": "我是坐飞机来的。飞机票很贵。", "pinyin": "Wǒ shì zuò fēijī lái de. Fēijī piào hěn guì.", "english": "I came by airplane. The plane ticket is very expensive." },
        { "speaker": "A", "chinese": "多少钱？", "pinyin": "Duōshǎo qián?", "english": "How much was it?" },
        { "speaker": "B", "chinese": "很贵！但是我很高兴来中国！", "pinyin": "Hěn guì! Dànshì wǒ hěn gāoxìng lái Zhōngguó!", "english": "Very expensive! But I'm very happy to come to China!" }
      ],
      "speakers": {
        "A": { "name": "小丽", "role": "朋友", "gender": "female" },
        "B": { "name": "大明", "role": "朋友", "gender": "male" }
      }
    },
    {
      "id": 2,
      "title": "How to Get to the Airport",
      "title_chinese": "怎么去机场",
      "lines": [
        { "speaker": "A", "chinese": "请问，去机场怎么走？", "pinyin": "Qǐngwèn, qù jīchǎng zěnme zǒu?", "english": "Excuse me, how do I get to the airport?" },
        { "speaker": "B", "chinese": "你可以坐地铁，也可以坐出租车。", "pinyin": "Nǐ kěyǐ zuò dìtiě, yě kěyǐ zuò chūzūchē.", "english": "You can take the subway, or you can take a taxi." },
        { "speaker": "A", "chinese": "机场远不远？", "pinyin": "Jīchǎng yuǎn bù yuǎn?", "english": "Is the airport far?" },
        { "speaker": "B", "chinese": "有一点远，坐地铁大概三十分钟。", "pinyin": "Yǒu yīdiǎn yuǎn, zuò dìtiě dàgài sānshí fēnzhōng.", "english": "A bit far, about 30 minutes by subway." }
      ],
      "speakers": {
        "A": { "name": "小华", "role": "旅客", "gender": "female" },
        "B": { "name": "小明", "role": "路人", "gender": "male" }
      }
    },
    {
      "id": 3,
      "title": "Is It Far?",
      "title_chinese": "远不远",
      "lines": [
        { "speaker": "A", "chinese": "学校远不远？", "pinyin": "Xuéxiào yuǎn bù yuǎn?", "english": "Is the school far?" },
        { "speaker": "B", "chinese": "不远，走路十分钟就到了。", "pinyin": "Bù yuǎn, zǒu lù shí fēnzhōng jiù dào le.", "english": "Not far, ten minutes on foot and you're there." },
        { "speaker": "A", "chinese": "好，我走路去。谢谢！", "pinyin": "Hǎo, wǒ zǒu lù qù. Xièxie!", "english": "Good, I'll walk. Thank you!" }
      ],
      "speakers": {
        "A": { "name": "小美", "role": "学生", "gender": "female" },
        "B": { "name": "王先生", "role": "路人", "gender": "male" }
      }
    },
    {
      "id": 4,
      "title": "Going to Beijing",
      "title_chinese": "去北京",
      "lines": [
        { "speaker": "A", "chinese": "你去北京了吗？", "pinyin": "Nǐ qù Běijīng le ma?", "english": "Did you go to Beijing?" },
        { "speaker": "B", "chinese": "去了！我是坐飞机去的。北京太好了！", "pinyin": "Qù le! Wǒ shì zuò fēijī qù de. Běijīng tài hǎo le!", "english": "Yes! I went by airplane. Beijing is amazing!" },
        { "speaker": "A", "chinese": "我以后也想去！买票贵吗？", "pinyin": "Wǒ yǐhòu yě xiǎng qù! Mǎi piào guì ma?", "english": "I want to go in the future too! Is it expensive to buy tickets?" },
        { "speaker": "B", "chinese": "还好，提前买比较便宜。", "pinyin": "Hái hǎo, tíqián mǎi bǐjiào piányí.", "english": "Not too bad, buying early is cheaper." }
      ],
      "speakers": {
        "A": { "name": "小丽", "role": "同学", "gender": "female" },
        "B": { "name": "小刚", "role": "同学", "gender": "male" }
      }
    }
