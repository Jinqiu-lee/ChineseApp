  "grammar_points": [
    {
      "number": 1,
      "title": "是...的 (shì...de) — Emphasizing Past Details",
      "explanation": "The 是(shì)...的(de) pattern emphasizes HOW, WHEN, or WHERE a past action happened. The verb goes between 是(shì) and 的(de). Formula: Subject + 是(shì) + [emphasized detail] + Verb + 的(de).",
      "examples": [
        {
          "chinese": "我是坐飞机来的。",
          "pinyin": "Wǒ shì zuò fēijī lái de.",
          "english": "I came (specifically) by airplane."
        },
        {
          "chinese": "他是昨天来的。",
          "pinyin": "Tā shì zuótiān lái de.",
          "english": "He came (specifically) yesterday."
        },
        {
          "chinese": "你是走路去的吗？。",
          "pinyin": "Nǐ shì zǒulù qù de ma?",
          "english": "Did you go by foot?"
        }
      ],
      "exercises": [
        {
          "question": "Say 'She came by taxi' using 是...的",
          "answer": "她是坐出租车来的。",
          "type": "production"
        },
