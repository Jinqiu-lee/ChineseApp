  "grammar_points": [
    {
      "number": 1,
      "title": "是...的 (shì...de) — Emphasizing Past Details",
      "explanation": "The 是...的 pattern emphasizes HOW, WHEN, or WHERE a past action happened. The verb goes between 是 and 的. Formula: Subject + 是 + [emphasized detail] + Verb + 的.",
      "examples": [
        { "chinese": "我是坐飞机来的。", "pinyin": "Wǒ shì zuò fēijī lái de.", "english": "I came (specifically) by airplane." },
        { "chinese": "他是昨天来的。", "pinyin": "Tā shì zuótiān lái de.", "english": "He came (specifically) yesterday." }
      ],
      "exercises": [
        { "question": "Say 'She came by taxi' using 是...的", "answer": "她是坐出租车来的。", "type": "production" },
        { "question": "What does 是...的 emphasize?", "answer": "HOW, WHEN, or WHERE a past action happened", "type": "concept" }
      ]
    },
    {
      "number": 2,
      "title": "Transportation with 坐 (zuò) — Take / Ride",
      "explanation": "坐 means 'to sit' but also 'to take' transportation you sit in. 坐 + vehicle: 坐飞机 (take airplane), 坐出租车 (take taxi), 坐地铁 (take subway). For bikes, use 骑: 骑车 (ride a bike).",
      "examples": [
        { "chinese": "我坐地铁去学校。", "pinyin": "Wǒ zuò dìtiě qù xuéxiào.", "english": "I take the subway to school." },
        { "chinese": "你坐出租车还是走路？", "pinyin": "Nǐ zuò chūzūchē háishi zǒu lù?", "english": "Do you take a taxi or walk?" }
      ],
      "exercises": [
        { "question": "Say 'I take the subway to go to the airport'", "answer": "我坐地铁去机场。", "type": "production" },
        { "question": "Which verb do you use for riding a bicycle?", "answer": "骑 (骑车)", "type": "concept" }
      ]
    },
    {
      "number": 3,
      "title": "Distance: 远 (yuǎn) and 近 (jìn)",
      "explanation": "远 (yuǎn) = far; 近 (jìn) = near/close. A-not-A question pattern: 远不远? (Is it far?). Answers: 很远 (very far), 不远 (not far), 有一点远 (a bit far).",
      "examples": [
        { "chinese": "北京远不远？", "pinyin": "Běijīng yuǎn bù yuǎn?", "english": "Is Beijing far?" },
        { "chinese": "不远，很近。", "pinyin": "Bù yuǎn, hěn jìn.", "english": "Not far, very close." }
      ],
      "exercises": [
        { "question": "Ask 'Is the restaurant far?' using A-not-A pattern", "answer": "饭馆远不远？", "type": "production" },
        { "question": "What is the opposite of 远?", "answer": "近", "type": "concept" }
      ]
    }
  ],
