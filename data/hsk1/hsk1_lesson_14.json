  "grammar_points": [
    {
      "number": 1,
      "title": "Completion Particle 了 (le) — Action Completed",
      "explanation": "了 after a verb shows the action is completed. Formula: Subject + Verb + 了 + Object. Negative: 没(有) + Verb (no 了). Question: Verb + 了 + 吗? or Verb + 了 + 没有?",
      "examples": [
        { "chinese": "我吃了米饭。", "pinyin": "Wǒ chī le mǐfàn.", "english": "I ate rice." },
        { "chinese": "她买了新衣服。", "pinyin": "Tā mǎi le xīn yīfu.", "english": "She bought new clothes." }
      ],
      "exercises": [
        { "question": "Say 'I drank tea' using 了", "answer": "我喝了茶。", "type": "production" },
        { "question": "How do you negate a 了 sentence?", "answer": "Use 没有 + Verb (remove 了)", "type": "concept" },
        { "question": "Fill in: 他___吃饭。(He ate. Use 了)", "answer": "了", "type": "fill_in_blank" }
      ]
    },
    {
      "number": 2,
      "title": "还没 (hái méi) — Haven't Yet",
      "explanation": "还没 + Verb means 'haven't done yet'. No 了 is used. 还 = still/yet; 没 = not (for actions). Formula: Subject + 还没 + Verb + (呢).",
      "examples": [
        { "chinese": "我还没吃。", "pinyin": "Wǒ hái méi chī.", "english": "I haven't eaten yet." },
        { "chinese": "他还没来。", "pinyin": "Tā hái méi lái.", "english": "He hasn't come yet." }
      ],
      "exercises": [
        { "question": "Say 'She hasn't bought clothes yet'", "answer": "她还没买衣服。", "type": "production" },
        { "question": "Fill in: 我___吃饭。(I haven't eaten yet)", "answer": "还没", "type": "fill_in_blank" }
      ]
    },
    {
      "number": 3,
      "title": "以前 and 以后 — Before and After",
      "explanation": "以前 (yǐqián) = before/previously. 以后 (yǐhòu) = after/later/in the future. They come before the main verb clause. Often paired with 现在 (now).",
      "examples": [
        { "chinese": "以前我是学生，现在我工作了。", "pinyin": "Yǐqián wǒ shì xuésheng, xiànzài wǒ gōngzuò le.", "english": "I was a student before, now I'm working." },
        { "chinese": "以后你想做什么？", "pinyin": "Yǐhòu nǐ xiǎng zuò shénme?", "english": "What do you want to do in the future?" }
      ],
      "exercises": [
        { "question": "Say 'I will go to China in the future'", "answer": "我以后去中国。", "type": "production" },
        { "question": "What is the opposite of 以前?", "answer": "以后", "type": "concept" }
      ]
    }
  ],
