  "grammar_point": {
    "title": "Measure words (量词 liàngcí)",
    "explanation": "In Chinese, you cannot say 'one book' directly. You need a measure word between the number and noun. 本 (běn) is used for books, 支 (zhī) for pens and pencils, 个 (gè) is the general measure word. Pattern: number + measure word + noun.",
    "examples": [
      { "chinese": "一个苹果", "pinyin": "yī gè píngguǒ", "english": "one apple" },
      { "chinese": "两本书", "pinyin": "liǎng běn shū", "english": "two books" }
    ]
  },
