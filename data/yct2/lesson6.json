  "grammar_point": {
    "title": "最 (zuì) — superlative 'most'",
    "explanation": "最 placed before an adjective or verb makes it superlative. 最喜欢 = like the most (favourite). 最高 = tallest. 最好 = best. This is much simpler than English superlatives — just add one word!",
    "examples": [
      { "chinese": "我最喜欢猫", "pinyin": "Wǒ zuì xǐhuān māo", "english": "I like cats the most" },
      { "chinese": "她最高", "pinyin": "Tā zuì gāo", "english": "She is the tallest" }
    ]
  },
