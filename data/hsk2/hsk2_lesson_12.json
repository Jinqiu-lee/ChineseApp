          ],
          "correct_pinyin": "Tā pǎo de hěn màn."
        },
        {
          "id": "hsk2_l12_g1_e3",
          "question": "What is the formula for the degree complement?",
          "type": "multiple_choice",
          "correct": "Verb + 得 + complement",
          "options": [
