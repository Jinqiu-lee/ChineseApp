    {
      "number": 3,
      "title": "了 indicating change of state",
      "explanation": "了 placed at the end of a sentence can indicate a change of state — something has become true that was not true before. Formula: Sentence + 了. For example: 她生病了 (She has gotten sick — a new situation). This is different from the 了 that marks a completed action.",
      "examples": [
        {
          "chinese": "她生病了。",
          "pinyin": "Tā shēng bìng le.",
          "english": "She has gotten sick."
        },
        {
          "chinese": "天冷了，要多穿衣服。",
          "pinyin": "Tiān lěng le, yào duō chuān yī fú.",
          "english": "The weather has turned cold; wear more clothes."
        }
      ],
