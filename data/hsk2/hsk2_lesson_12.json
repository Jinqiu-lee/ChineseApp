  "grammar_points": [
    {
      "number": 1,
      "title": "程度补语 — Degree Complement V+得+complement",
      "explanation": "The degree complement describes the degree or result of an action. Formula: Verb + 得 + complement (adjective or adverb phrase). For example: 跑得快 (run fast), 说得好 (speak well). When there is an object, the verb is repeated: 他中文说得很好。",
      "examples": [
        {
          "chinese": "他跑得非常快。",
          "pinyin": "Tā pǎo de fēi cháng kuài.",
          "english": "He runs extremely fast."
        },
        {
          "chinese": "她汉语说得很好。",
          "pinyin": "Tā Hàn yǔ shuō de hěn hǎo.",
          "english": "She speaks Chinese very well."
        }
      ],
      "exercises": [
        {
          "id": "hsk2_l12_g1_e1",
          "question": "Fill in: 他写___很好。(He writes very well.)",
          "type": "multiple_choice",
          "correct": "得",
          "options": [
            "得",
