  "grammar_points": [
    {
      "number": 1,
      "title": "Using 最 (zuì) for superlative",
      "explanation": "最 means 'most' or 'best'. It is used before adjectives to form the superlative.",
      "examples": [
        {
          "chinese": "九月去北京旅游最好。",
          "pinyin": "Jiǔ yuè qù Běi jīng lǚ yóu zuì hǎo.",
