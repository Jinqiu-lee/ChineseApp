  "grammar_points": [
    {
      "number": 2,
      "title": "Because – 因为",
      "explanation": "因为 means 'because'. It introduces the reason for something.",
      "examples": [
        {
          "chinese": "因为天气很好。",
          "pinyin": "Yīn wèi tiān qì hěn hǎo.",
          "english": "Because the weather is very good."
        },
        {
          "chinese": "因为我喜欢北京。",
          "pinyin": "Yīn wèi wǒ xǐ huān Běi jīng.",
          "english": "Because I like Beijing."
        }
      ],
