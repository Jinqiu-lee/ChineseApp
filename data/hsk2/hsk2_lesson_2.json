  "grammar_points": [
    {
      "number": 1,
      "title": "用「还是」的疑问句 — Questions with háishì",
      "explanation": "还是 (hái shì) is used to form alternative questions offering two choices (A or B?). Structure: A + 还是 + B? The listener must choose one. This differs from 或者 (or) which is used in statements, not questions.",
      "examples": [
        {
          "chinese": "你是上午还是下午去？",
          "pinyin": "Nǐ shì shàng wǔ hái shì xià wǔ qù?",
          "english": "Are you going in the morning or in the afternoon?"
        },
        {
          "chinese": "你喝咖啡还是牛奶？",
          "pinyin": "Nǐ hē kā fēi hái shì niú nǎi?",
          "english": "Do you drink coffee or milk?"
        }
      ],
