    {
      "number": 2,
      "title": "疑问代词 — Interrogative Pronouns",
      "explanation": "Chinese interrogative pronouns include: 什么 (what), 谁 (who), 哪/哪里 (which/where), 什么时候 (when), 怎么 (how), 为什么 (why), 几 (how many). They stay in the same position in the sentence as the information they replace — no word order inversion is needed.",
      "examples": [
        {
          "chinese": "你什么时候起床？",
          "pinyin": "Nǐ shén me shí hou qǐ chuáng?",
          "english": "When do you get up?"
        },
        {
          "chinese": "你每天几点上班？",
          "pinyin": "Nǐ měi tiān jǐ diǎn shàng bān?",
          "english": "What time do you go to work every day?"
