  "grammar_points": [
    {
      "number": 1,
      "title": "动态助词「过」— Aspect Particle guò (past experience)",
      "explanation": "过 (guò) is placed after a verb to indicate that the speaker has had a past experience of doing something at least once. Formula: Verb + 过. Negation: 没 + Verb + 过. Question: Verb + 过 + 吗? For example: 我吃过北京烤鸭。(I have eaten Peking duck before.) 我没吃过。(I have never eaten it.)",
      "examples": [
        {
          "chinese": "你看过那部电影吗？",
          "pinyin": "Nǐ kàn guò nà bù diàn yǐng ma?",
          "english": "Have you seen that movie?"
        },
        {
          "chinese": "我没去过中国，想去看看。",
          "pinyin": "Wǒ méi qù guò zhōng guó, xiǎng qù kàn kàn.",
          "english": "I have never been to China; I'd like to go and see it."
        }
      ],
      "exercises": [
