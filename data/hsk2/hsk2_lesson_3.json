  "grammar_points": [
    {
      "number": 1,
      "title": "「的」字短语 — Nominal Clause with de",
      "explanation": "When 的(de) follows an adjective or a modifier, it turns the phrase into a noun equivalent meaning 'the one that is…'. Structure: Adjective/Modifier + 的 = noun phrase. For example: 红色的 means 'the red one'; 我的 means 'mine'. This is used when the noun is clear from context and does not need to be repeated.",
      "examples": [
        {
          "chinese": "左边那件红色的是我的。",
          "pinyin": "Zuǒ bian nà jiàn hóng sè de shì wǒ de.",
          "english": "The red one on the left is mine."
        },
        {
          "chinese": "大的给他，小的给我。",
          "pinyin": "Dà de gěi tā, xiǎo de gěi wǒ.",
