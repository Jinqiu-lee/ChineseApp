  "grammar_points": [
    {
      "number": 1,
      "title": "「是...的」结构 — The Structure shì...de",
      "explanation": "The 是...的 structure is used to emphasise information about a past event — specifically the time, place, manner, or agent. The action has already happened; 是...的 focuses on the circumstances. Structure: Subject + 是 + [emphasis: time/place/manner] + Verb + 的. The object can go before or after 的.",
      "examples": [
        {
          "chinese": "你是在哪里认识他的？",
          "pinyin": "Nǐ shì zài nǎ lǐ rèn shi tā de?",
          "english": "Where (exactly) did you meet him?"
        },
        {
          "chinese": "他是昨天来的。",
          "pinyin": "Tā shì zuó tiān lái de.",
          "english": "He came yesterday (emphasising when)."
        }
      ],
      "exercises": [
        {
          "question": "What does the 是...的 structure emphasise?",
          "type": "multiple_choice",
          "correct": "Circumstances of a past event (time, place, manner)",
          "options": [
            "Circumstances of a past event (time, place, manner)",
            "Future plans",
            "Ongoing actions",
            "Habitual actions"
          ]
        },
        {
          "question": "Which sentence uses 是...的 correctly?",
          "type": "multiple_choice",
          "correct": "他是在北京认识她的。",
          "options": [
            "他是在北京认识她的。",
            "他在北京是认识她。",
            "是他在北京认识她。",
            "他认识是在北京她的。"
          ],
          "correct_pinyin": "Tā shì zài Běijīng rèn shi tā de."
        },
        {
          "question": "Fill in: 你___几点来___？(When did you come?) — Use 是...的",
          "type": "multiple_choice",
          "correct": "是 / 的",
          "options": [
            "是 / 的",
            "在 / 了",
            "已经 / 了",
            "要 / 吗"
          ]
        },
        {
          "question": "What does 是谁介绍的 mean?",
          "type": "multiple_choice",
          "correct": "Who introduced (you/them)",
          "options": [
            "Who introduced (you/them)",
            "Who told you",
            "Who met you first",
            "Who knows you"
          ],
          "option_pinyin": [
            "shì shuí jiè shào de",
            "shì shuí gào su nǐ de",
            "shì shuí xiān jiàn miàn de",
            "shì shuí rèn shi nǐ de"
          ]
        }
      ]
    },
    {
      "number": 2,
      "title": "副词「也」indicating time — yě for simultaneous action",
      "explanation": "也 (yě) means 'also / too / as well'. It is placed before the verb to indicate that the subject shares in an action or state. Structure: Subject + 也 + Verb/Adjective. When indicating parallel time or situation: 他也在那里 (He was also there). 也 can be used with 正在 or other time markers.",
      "examples": [
        {
          "chinese": "他也在公司上班。",
          "pinyin": "Tā yě zài gōng sī shàng bān.",
          "english": "He also works at the company."
        },
        {
          "chinese": "我也认识他。",
          "pinyin": "Wǒ yě rèn shi tā.",
          "english": "I also know him."
        }
      ],
      "exercises": [
        {
          "question": "Where does 也 go in a sentence?",
          "type": "multiple_choice",
          "correct": "Before the verb",
          "options": [
            "Before the verb",
