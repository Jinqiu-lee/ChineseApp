  "grammar_points": [
    {
      "number": 1,
      "title": "动态助词「着」— Aspect Particle zhe (ongoing state)",
      "explanation": "着 (zhe) is placed after a verb to indicate an ongoing state or condition. It describes a static result that continues to exist. Formula: Verb + 着. For example: 开着 (is open / remains open), 坐着 (sitting). It can also describe a simultaneous action: 坐着看书 (sit and read). Do not confuse with 在...呢 which indicates an ongoing action in progress.",
      "examples": [
        {
          "chinese": "门开着。",
          "pinyin": "Mén kāi zhe.",
          "english": "The door is open."
        },
        {
          "chinese": "他站着看电视。",
          "pinyin": "Tā zhàn zhe kàn diàn shì.",
          "english": "He is standing and watching TV."
        }
      ],
      "exercises": [
