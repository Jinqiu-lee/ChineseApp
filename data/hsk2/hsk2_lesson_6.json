  "grammar_points": [
    {
      "number": 1,
      "title": "虽然...但是... — Although...But...",
      "explanation": "虽然 (suī rán) means 'although / even though' and 但是 (dàn shì) means 'but / however'. They always appear together as a pair. Structure: 虽然 + Clause 1, 但是 + Clause 2. The subject can appear before 虽然 or after it. Note: In Chinese, 但是 must follow even though English can drop 'but'.",
      "examples": [
        {
          "chinese": "虽然很好吃，但是我已经饱了。",
          "pinyin": "Suī rán hěn hǎo chī, dàn shì wǒ yǐ jīng bǎo le.",
          "english": "Although it's very delicious, I'm already full."
        },
        {
          "chinese": "虽然贵，但是质量很好。",
          "pinyin": "Suī rán guì, dàn shì zhì liàng hěn hǎo.",
          "english": "Although it's expensive, the quality is very good."
        }
      ],
      "exercises": [
