    {
      "number": 3,
      "title": "了 indicating Change of State",
      "explanation": "了 (le) placed at the end of a sentence can indicate a change of state or a new situation. This is different from 了 after a verb (completed action). Sentence-final 了 often translates as 'now', 'already', or signals that something is different. Examples: 我饱了 (I'm full now — I wasn't before); 天黑了 (It's gotten dark); 不吃了 (Not eating anymore — stopping now).",
      "examples": [
        {
          "chinese": "我已经饱了，不吃了。",
          "pinyin": "Wǒ yǐ jīng bǎo le, bù chī le.",
          "english": "I'm already full; I'm not eating anymore."
        },
        {
          "chinese": "为什么不吃了？",
          "pinyin": "Wèi shén me bù chī le?",
          "english": "Why don't you eat anymore?"
        }
      ],
