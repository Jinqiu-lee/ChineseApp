  "dialogues": [
    {
      "id": 1,
      "title": "New Year Greetings",
      "title_chinese": "新年祝福",
      "speakers": {
        "A": {
          "name": "但丁",
          "role": "朋友",
          "gender": "male",
          "name_pinyin": "Dàn dīng",
          "role_pinyin": "péng yǒu"
        },
        "B": {
          "name": "奥斯汀",
          "role": "朋友",
          "gender": "female",
          "name_pinyin": "Ào sī tīng",
          "role_pinyin": "péng yǒu"
        }
      },
      "lines": [
        {
          "speaker": "A",
          "chinese": "新年快乐！祝你新的一年快乐，身体健康！",
          "pinyin": "Xīn nián kuài lè! Zhù nǐ xīn de yì nián kuài lè, shēn tǐ jiàn kāng!",
          "english": "Happy New Year! Wishing you happiness and good health in the new year!"
        },
        {
          "speaker": "B",
          "chinese": "谢谢！也祝你新年快乐！这是送给你的礼物。",
          "pinyin": "Xiè xie! Yě zhù nǐ xīn nián kuài lè! Zhè shì sòng gěi nǐ de lǐ wù.",
          "english": "Thank you! Happy New Year to you too! This is a gift for you."
        },
        {
          "speaker": "A",
          "chinese": "太感谢了！我还有一件礼物要送给你。",
          "pinyin": "Tài gǎn xiè le! Wǒ hái yǒu yí jiàn lǐ wù yào sòng gěi nǐ.",
          "english": "Thank you so much! I also have a gift to give you."
        },
        {
          "speaker": "B",
          "chinese": "你真好！希望大家今年都快乐。",
          "pinyin": "Nǐ zhēn hǎo! Xī wàng dà jiā jīn nián dōu kuài lè.",
          "english": "You're so kind! I hope everyone is happy this year."
        },
        {
          "speaker": "A",
          "chinese": "是啊！我们一起过节，真开心！明年你得再来！",
          "pinyin": "Shì a! Wǒ men yì qǐ guò jié, zhēn kāi xīn! Míng nián nǐ děi zài lái!",
          "english": "Indeed! Celebrating together is truly joyful! You must come again next year!"
        }
      ],
      "title_pinyin": "Xīn nián zhù fú"
    },
    {
      "id": 2,
      "title": "Planning the Celebration",
      "title_chinese": "准备过节",
      "speakers": {
        "A": {
          "name": "鲁迅",
          "role": "朋友",
          "gender": "male",
          "name_pinyin": "Lǔ Xùn",
          "role_pinyin": "péng yǒu"
        },
        "B": {
          "name": "加缪",
          "role": "朋友",
          "gender": "male",
          "name_pinyin": "Jiā miù",
          "role_pinyin": "péng yǒu"
        }
      },
      "lines": [
        {
          "speaker": "A",
          "chinese": "新年快到了，大家得一起庆祝！",
          "pinyin": "Xīn nián kuài dào le, dà jiā děi yì qǐ qìng zhù!",
          "english": "The New Year is almost here; everyone must celebrate together!"
        },
        {
          "speaker": "B",
          "chinese": "好啊！我希望大家都能来。还有谁没来？",
          "pinyin": "Hǎo a! Wǒ xī wàng dà jiā dōu néng lái. Hái yǒu shéi méi lái?",
          "english": "Great! I hope everyone can come. Who else hasn't come yet?"
        },
        {
          "speaker": "A",
          "chinese": "但丁还没来。他说还在路上。",
          "pinyin": "Dàn Dīng hái méi lái. Tā shuō hái zài lù shàng.",
          "english": "Dante still hasn't come. He said he's still on the way."
        },
        {
          "speaker": "B",
          "chinese": "没关系，我们先等一下。礼物买好了吗？",
          "pinyin": "Méi guān xi, wǒ men xiān děng yí xià. Lǐ wù mǎi hǎo le ma?",
          "english": "No worries; let's wait a moment. Have you bought the gifts?"
        },
        {
          "speaker": "A",
          "chinese": "买好了！我还要再买一件，送给波伏娃。",
          "pinyin": "Mǎi hǎo le! Wǒ hái yào zài mǎi yí jiàn, sòng gěi Bō Fú Wá.",
          "english": "I have! I also want to buy one more to give to Beauvoir."
        },
        {
          "speaker": "B",
          "chinese": "你真好！祝大家节日快乐，希望今年一切顺利！",
          "pinyin": "Nǐ zhēn hǎo! Zhù dà jiā jié rì kuài lè, xī wàng jīn nián yí qiè shùn lì!",
          "english": "You're so kind! Wishing everyone a happy holiday, and I hope this year goes smoothly for all!"
        }
      ],
      "title_pinyin": "Zhǔn bèi guò jié"
    }
