  "grammar_points": [
    {
      "number": 1,
      "title": "副词「还」(2) — Adverb hai second usage (still / also / in addition)",
      "explanation": "还(hái) has two main meanings: (1) still — indicating something continues to be true: 她(tā)还(hái)在(zài)等(děng)。(She is still waiting.) (2) in addition / also — adding more information: 他(tā)会(huì)说(shuō)英语，还(hái)会(huì)说(shuō)法语。(He can speak English and also French.) Context determines which meaning applies.",
      "examples": [
        {
          "chinese": "她还在等，你快去吧。",
          "pinyin": "Tā hái zài děng, nǐ kuài qù ba.",
          "english": "She is still waiting; you should go quickly."
        },
        {
          "chinese": "我还要再送你一件礼物！",
          "pinyin": "Wǒ hái yào zài sòng nǐ yí jiàn lǐ wù!",
          "english": "I also want to give you one more gift!"
        }
      ],
