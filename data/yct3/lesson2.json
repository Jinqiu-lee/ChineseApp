  "grammar_point": {
    "title": "从...到... (cóng...dào...) — from...to...",
    "explanation": "This pattern expresses travel from one place to another. 从 = from, 到 = to/arrive. Also useful: 离 (lí) expresses distance between two places — 离学校很近 = close to school. 怎么 before a verb asks 'how': 怎么去 = how to go.",
    "examples": [
      { "chinese": "从家到公园", "pinyin": "Cóng jiā dào gōngyuán", "english": "From home to the park" },
      { "chinese": "我家离学校很远", "pinyin": "Wǒ jiā lí xuéxiào hěn yuǎn", "english": "My home is far from school" }
    ]
  },
