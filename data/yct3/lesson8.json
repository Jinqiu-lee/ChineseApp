  "grammar_point": {
    "title": "太...了 (tài...le) — Too...",
    "explanation": "太 (tài) before an adjective + 了 at the end means 'too' as in 'excessively'. 太贵了 = too expensive. 太好了 = wonderful / too good. This pattern shows strong feeling. 能...吗 = Can...? is used for making requests politely.",
    "examples": [
      { "chinese": "太好吃了！", "pinyin": "Tài hǎochī le!", "english": "So delicious! (too tasty!)" },
      { "chinese": "你能来吗？", "pinyin": "Nǐ néng lái ma?", "english": "Can you come?" }
    ]
  },
