  "learn_content": {
    "rules": [
      "ang = 'ahng', eng = 'ung', ing = 'eeng', ong = 'oong'",
      "y is used when i or ü starts a syllable alone: yi, yu, ye, yue",
      "w is used when u starts a syllable alone: wu, wa, wo, wei",
      "Distinguish -n finals (an/en/in) from -ng finals (ang/eng/ing)"
    ],
    "spelling_rules": [
      {
        "title": "y and w — standalone vowel syllables",
        "rule": "y replaces i / w replaces u when no initial is present",
        "examples": [
          {
            "pinyin": "yī",
            "note": "y + i = yi (one)",
            "audio_key": "yi1"
          },
          {
            "pinyin": "yú",
            "note": "y + ü = yu",
            "audio_key": "yu2"
          },
          {
            "pinyin": "wū",
            "note": "w + u = wu (five)",
            "audio_key": "wu1"
          }
        ]
      },
      {
        "title": "Initial + ang",
        "rule": "b p m f d t n l g k h zh ch sh r z c s combine with 'ang'",
        "examples": [
          { "pinyin": "yáng",  "note": "y (standalone)", "audio_key": "yang2" },
          { "pinyin": "wáng",  "note": "w (standalone)", "audio_key": "wang2" },
          { "pinyin": "zhāng", "note": "zh + ang",       "audio_key": "zhang1" },
          { "pinyin": "shāng", "note": "sh + ang",       "audio_key": "shang1" }
        ]
      },
      {
        "title": "Initial + eng",
        "rule": "b p m f d t n l g k h zh ch sh r z c s combine with 'eng'",
        "examples": [
          { "pinyin": "néng",  "note": "n + eng",  "audio_key": "neng2" },
          { "pinyin": "wèng",  "note": "w (standalone)", "audio_key": "weng4" }
        ]
      },
      {
        "title": "Initial + ing",
        "rule": "b p m d t n l j q x combine with 'ing'",
        "examples": [
          { "pinyin": "míng",  "note": "m + ing",  "audio_key": "ming2" },
          { "pinyin": "yīng",  "note": "y (standalone)", "audio_key": "ying1" }
        ]
      },
      {
        "title": "Initial + ong",
        "rule": "d t n l g k h zh ch sh r z c s combine with 'ong'",
        "examples": [
          { "pinyin": "dōng",  "note": "d + ong",  "audio_key": "dong1" },
          { "pinyin": "zhōng", "note": "zh + ong", "audio_key": "zhong1" },
          { "pinyin": "chóng", "note": "ch + ong", "audio_key": "chong2" },
          { "pinyin": "cóng",  "note": "c + ong",  "audio_key": "cong2" }
        ]
      }
    ]
  },
