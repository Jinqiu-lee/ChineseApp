          { "pinyin": "dì",  "note": "d + i", "audio_key": "di4" },
          { "pinyin": "tí",  "note": "t + i", "audio_key": "ti2" },
          { "pinyin": "nǐ",  "note": "n + i", "audio_key": "ni3" },
          { "pinyin": "lì",  "note": "l + i", "audio_key": "li4" }
        ]
      },
      {
        "title": "Initial + u",
        "rule": "b p m f d t n l combine with 'u'",
        "examples": [
          { "pinyin": "bù",  "note": "b + u", "audio_key": "bu4" },
          { "pinyin": "pù",  "note": "p + u", "audio_key": "pu4" },
          { "pinyin": "mù",  "note": "m + u", "audio_key": "mu4" },
          { "pinyin": "fú",  "note": "f + u", "audio_key": "fu2" },
          { "pinyin": "dù",  "note": "d + u", "audio_key": "du4" },
          { "pinyin": "tù",  "note": "t + u", "audio_key": "tu4" },
          { "pinyin": "nǔ",  "note": "n + u", "audio_key": "nu3" },
          { "pinyin": "lù",  "note": "l + u", "audio_key": "lu4" }
        ]
      },
      {
        "title": "Initial + ü",
        "rule": "Only n and l combine with 'ü' from this set",
        "examples": [
          { "pinyin": "nǚ",  "note": "n + ü", "audio_key": "nv3" },
          { "pinyin": "lǜ",  "note": "l + ü", "audio_key": "lv4" }
        ]
      }
    ]
