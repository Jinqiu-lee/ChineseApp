  "learn_content": {
    "tones": [
      {
        "tone": 1,
        "mark": "ā",
        "name": "1st Tone",
        "desc": "High and level — hold flat",
        "example_syllable": "mā",
        "example_meaning": "mother"
      },
      {
        "tone": 2,
        "mark": "á",
        "name": "2nd Tone",
        "desc": "Rising — like asking 'really?'",
        "example_syllable": "má",
        "example_meaning": "hemp"
      },
      {
        "tone": 3,
        "mark": "ǎ",
        "name": "3rd Tone",
        "desc": "Dipping — down then up",
        "example_syllable": "mǎ",
        "example_meaning": "horse"
      },
      {
        "tone": 4,
        "mark": "à",
        "name": "4th Tone",
        "desc": "Falling — sharp and fast",
        "example_syllable": "mà",
        "example_meaning": "scold"
      }
    ],
    "rules": [
      "ü is written as v in file names but always displayed as ü",
      "Neutral tone (轻声) has no tone mark — it is short and light",
      "Every Chinese syllable has exactly one tone"
    ],
    "spelling_rules": [
      {
        "title": "Initial + a",
        "rule": "b p m f d t n l combine with 'a'",
        "examples": [
          { "pinyin": "bā",  "note": "b + a", "audio_key": "ba1" },
          { "pinyin": "pá",  "note": "p + a", "audio_key": "pa2" },
          { "pinyin": "mā",  "note": "m + a", "audio_key": "ma1" },
          { "pinyin": "fà",  "note": "f + a", "audio_key": "fa4" },
          { "pinyin": "dà",  "note": "d + a", "audio_key": "da4" },
          { "pinyin": "tā",  "note": "t + a", "audio_key": "ta1" },
          { "pinyin": "nǎ",  "note": "n + a", "audio_key": "na3" },
          { "pinyin": "lā",  "note": "l + a", "audio_key": "la1" }
        ]
      },
      {
        "title": "Initial + o",
        "rule": "b p m f combine with 'o'",
        "examples": [
          { "pinyin": "bō",  "note": "b + o", "audio_key": "bo1" },
          { "pinyin": "pó",  "note": "p + o", "audio_key": "po2" },
          { "pinyin": "mó",  "note": "m + o", "audio_key": "mo2" },
          { "pinyin": "fó",  "note": "f + o", "audio_key": "fo2" }
        ]
      },
      {
        "title": "Initial + e",
        "rule": "m d t n l combine with 'e'",
        "examples": [
          { "pinyin": "mē",  "note": "m + e", "audio_key": "me1" },
          { "pinyin": "dé",  "note": "d + e", "audio_key": "de2" },
          { "pinyin": "tè",  "note": "t + e", "audio_key": "te4" },
          { "pinyin": "nè",  "note": "n + e", "audio_key": "ne4" },
          { "pinyin": "lè",  "note": "l + e", "audio_key": "le4" }
        ]
      },
      {
        "title": "Initial + i",
        "rule": "b p m d t n l combine with 'i' (f does not combine with i)",
        "examples": [
          { "pinyin": "bǐ",  "note": "b + i", "audio_key": "bi3" },
          { "pinyin": "pí",  "note": "p + i", "audio_key": "pi2" },
