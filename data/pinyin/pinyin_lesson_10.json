    "rules": [
      "FULL INITIALS: b p m f | d t n l | g k h | j q x | zh ch sh r | z c s | y w",
      "SIMPLE FINALS: a o e i u ü",
      "COMPOUND FINALS: ai ei ui ao ou iu ie üe er",
      "NASAL FINALS: an en in un ün | ang eng ing ong",
      "MEDIAL FINALS: ia iao ian iang | ua uai uo uan uang | üan",
      "WHOLE SYLLABLES: zhi chi shi ri | zi ci si | yi wu yu | ye yue yuan yin yun ying"
    ],
