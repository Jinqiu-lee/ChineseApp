  "learn_content": {
    "rules": [
      "an = 'ahn', en = 'un' (as in under), in = 'een'",
      "un = 'wen', ün = 'yün' (lips rounded)",
      "z sounds like 'dz', c sounds like 'ts', s is like English s",
      "z/c/s are flat-tongue — tongue stays flat (unlike zh/ch/sh)"
    ],
    "spelling_rules": [
      {
        "title": "Initial + an",
        "rule": "b p m f d t n l g k h combine with 'an'",
        "examples": [
          {
            "pinyin": "bān",
            "note": "b + an",
            "audio_key": "ban1"
          },
          {
            "pinyin": "kàn",
            "note": "k + an",
            "audio_key": "kan4"
          }
        ]
      },
      {
        "title": "Initial + en",
        "rule": "b p m f d n g h zh ch sh r z combine with 'en'",
        "examples": [
          {
            "pinyin": "mén",
            "note": "m + en",
            "audio_key": "men2"
          },
          {
            "pinyin": "fēn",
            "note": "f + en",
            "audio_key": "fen1"
          },
          {
            "pinyin": "rén",
            "note": "r + en",
            "audio_key": "ren2"
          }
        ]
      },
      {
        "title": "Initial + in",
        "rule": "b p m n l j q x combine with 'in'",
        "examples": [
          {
            "pinyin": "nín",
            "note": "n + in",
            "audio_key": "nin2"
          },
          {
            "pinyin": "xīn",
            "note": "x + in",
            "audio_key": "xin1"
          }
        ]
      },
      {
        "title": "Initial + ün",
        "rule": "j q x combine with 'ün' (written as jun qun xun — umlaut omitted after j q x)",
        "examples": [
          {
            "pinyin": "jūn",
            "note": "j + ün",
            "audio_key": "jun1"
          }
        ]
      }
    ]
  },
