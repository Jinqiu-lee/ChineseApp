  "learn_content": {
    "rules": [
      "j, q, x + ü → written as ju, qu, xu (ü dots dropped, no ambiguity)",
      "j, q, x NEVER combine with u — so ju always means jü",
      "ia = 'ya', iao = 'yow', ian = 'yen', iang = 'yang'",
      "ua = 'wa', uai = 'why', uo = 'wo', uan = 'wan', uang = 'wang'",
      "When a compound final starts a syllable: ia→ya, ua→wa, üan→yuan"
    ],
    "spelling_rules": [
      {
        "title": "Initial + ia",
        "rule": "j q x n l combine with 'ia'",
        "examples": [
          {
            "pinyin": "jiā",
            "note": "j + ia",
            "audio_key": "jia1"
          }
        ]
      },
      {
        "title": "Initial + ian",
        "rule": "b p m d t n l j q x combine with 'ian'",
        "examples": [
          {
            "pinyin": "qián",
            "note": "q + ian",
            "audio_key": "qian2"
          },
          {
            "pinyin": "xiān",
            "note": "x + ian",
            "audio_key": "xian1"
          }
        ]
      },
      {
        "title": "Initial + iang",
        "rule": "n l j q x combine with 'iang'",
        "examples": [
          {
            "pinyin": "liáng",
            "note": "l + iang",
            "audio_key": "liang2"
          }
        ]
      },
      {
        "title": "Initial + ua",
        "rule": "g k h zh ch sh r combine with 'ua'",
        "examples": [
          {
            "pinyin": "guā",
            "note": "g + ua",
            "audio_key": "gua1"
          }
        ]
      },
      {
        "title": "Initial + uo",
        "rule": "d t n l g k h zh ch sh r z c s combine with 'uo'",
        "examples": [
          {
            "pinyin": "shuō",
            "note": "sh + uo",
            "audio_key": "shuo1"
          },
          {
            "pinyin": "zuò",
            "note": "z + uo",
            "audio_key": "zuo4"
          }
        ]
      },
      {
        "title": "Initial + uan",
        "rule": "d t n l g k h zh ch sh r z c s combine with 'uan'",
        "examples": [
          {
            "pinyin": "guān",
            "note": "g + uan",
            "audio_key": "guan1"
          }
        ]
      }
    ]
  },
