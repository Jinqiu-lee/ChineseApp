  "learn_content": {
    "rules": [
      "ai = 'eye', ei = 'ay', ui = 'way'",
      "ao = 'ow' (as in cow), ou = 'oh', iu = 'yo'",
      "j, q, x are ONLY used with i and ü finals — never a, o, u",
      "j + ü = ju (the ü dots are dropped after j, q, x)"
    ],
    "spelling_rules": [
      {
        "title": "Initial + ei",
        "rule": "b p m f l g combine with 'ei'",
        "examples": [
          {
            "pinyin": "bēi",
            "note": "b + ei",
            "audio_key": "bei1"
          }
        ]
      },
      {
        "title": "Initial + ou",
        "rule": "m t n l g k h combine with 'ou'",
        "examples": [
          {
            "pinyin": "gǒu",
            "note": "g + ou",
            "audio_key": "gou3"
          }
        ]
      },
      {
        "title": "j q x + i",
        "rule": "j q x combine with 'i'",
        "examples": [
          {
            "pinyin": "jī",
            "note": "j + i",
            "audio_key": "ji1"
          },
          {
            "pinyin": "qī",
            "note": "q + i",
            "audio_key": "qi1"
          }
        ]
      }
    ]
  },
