  "learn_content": {
    "rules": [
      "ai = 'eye', ei = 'ay', ui = 'way'",
      "ao = 'ow' (as in cow), ou = 'oh', iu = 'yo'",
      "j, q, x are ONLY used with i and ü finals — never a, o, u",
      "j + ü = ju (the ü dots are dropped after j, q, x)"
    ],
