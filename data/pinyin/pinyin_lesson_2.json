        "examples": [
          { "pinyin": "jī",   "note": "j + i",  "audio_key": "ji1" },
          { "pinyin": "qī",   "note": "q + i",  "audio_key": "qi1" },
          { "pinyin": "xī",   "note": "x + i",  "audio_key": "xi1" }
        ]
      }
    ]
  },
