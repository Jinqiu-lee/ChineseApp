  "learn_content": {
    "rules": [
      "zhi/chi/shi/ri — the 'i' here is a special tongue-position vowel, not the normal 'i'",
      "zi/ci/si — similar buzz vowel, tongue stays flat",
      "yi = y + i (standalone i), wu = w + u (standalone u), yu = y + ü",
      "ye = i + e, yue = ü + e, yuan = ü + an, yin = i + n, yun = ü + n, ying = i + ng"
    ],
    "spelling_rules": [
      {
        "title": "zhi chi shi ri — whole syllables",
        "rule": "zh ch sh r + 'i' form complete syllables — the 'i' is a special buzz vowel, not normal 'i'",
        "examples": [
          {
            "pinyin": "zhī",
            "note": "zh + (buzz-i)",
            "audio_key": "zhi1"
          },
          {
            "pinyin": "chī",
            "note": "ch + (buzz-i)",
            "audio_key": "chi1"
          },
          {
            "pinyin": "shī",
            "note": "sh + (buzz-i)",
            "audio_key": "shi1"
          }
        ]
      },
      {
        "title": "zi ci si — whole syllables",
        "rule": "z c s + 'i' form complete syllables — tongue stays flat, not curled",
        "examples": [
          {
            "pinyin": "sī",
            "note": "s + (flat-i)",
            "audio_key": "si1"
          }
        ]
      },
      {
        "title": "zh ch sh r + compound finals",
        "rule": "Retroflexes combine freely with most compound finals",
        "examples": [
          {
            "pinyin": "zhōng",
            "note": "zh + ong",
            "audio_key": "zhong1"
          }
        ]
      },
      {
        "title": "z c s + compound finals",
        "rule": "Sibilants z c s combine with ao ou an ang ong etc.",
        "examples": [
          {
            "pinyin": "cóng",
            "note": "c + ong",
            "audio_key": "cong2"
          },
          {
            "pinyin": "sān",
            "note": "s + an",
            "audio_key": "san1"
          }
        ]
      }
    ]
  },
