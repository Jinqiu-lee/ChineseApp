  "learn_content": {
    "rules": [
      "Neutral tone (轻声): no tone mark, very short and light — never stressed",
      "Common in: kinship terms (māma), particles (de, le, ma), complement words",
      "Erhua (儿化): add 儿 after a syllable, the final merges with 'r' sound",
      "哪 + 儿 → 哪儿 (nǎr) — the final disappears, 'r' colors the vowel",
      "Erhua is common in Beijing dialect and casual speech"
    ],
    "spelling_rules": [
      {
        "title": "Neutral tone syllables (轻声)",
        "rule": "Neutral tone has no mark — written without a tone number. It is short and unstressed.",
        "examples": [
          {
            "pinyin": "māma",
            "note": "妈妈 — the 2nd ma is neutral (mom)",
            "audio_key": "ma1_ma0"
          },
          {
            "pinyin": "bàba",
            "note": "爸爸 — the 2nd ba is neutral (dad)",
            "audio_key": "ba4_ba0"
          },
          {
            "pinyin": "gēge",
            "note": "哥哥 — the 2nd ge is neutral (older brother)",
            "audio_key": "ge1_ge0"
          },
          {
            "pinyin": "mèimei",
            "note": "妹妹 — the 2nd mei is neutral (younger sister)",
            "audio_key": "mei4_mei0"
          },
          {
            "pinyin": "nǐ de",
            "note": "你的 — de is always neutral (your)",
            "audio_key": "de0"
          },
          {
            "pinyin": "lái le",
            "note": "来了 — le is always neutral (came)",
            "audio_key": "le0"
          }
        ]
      },
      {
        "title": "Erhua (儿化) spelling",
        "rule": "Add 儿 (r) after a syllable — the final merges with 'r'. Written with 'r' suffix.",
        "examples": [
          {
            "pinyin": "nǎr",
            "note": "哪儿 — nǎ + r → nǎr (where)",
            "audio_key": "nar3"
          },
          {
            "pinyin": "zhèr",
            "note": "这儿 — zhè + r → zhèr (here)",
            "audio_key": "zher4"
          },
          {
            "pinyin": "nàr",
            "note": "那儿 — nà + r → nàr (there)",
            "audio_key": "nar4"
          }
        ]
      }
    ]
  },
