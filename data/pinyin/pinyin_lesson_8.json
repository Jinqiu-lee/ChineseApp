  "title": "Tone Sandhi: 一 and 不",
  "emoji": "🔄",
  "subtitle": "yī changes tone · bù becomes bú",
  "description": "Learn how the tones of 一(yī) and 不(bù) change depending on what follows them.",
  "new_finals": [],
  "review_finals": [],
