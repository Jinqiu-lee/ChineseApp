  "review_initials": [],
  "sandhi_rules": {
    "yi": {
      "base_tone": 1,
      "rules": [
        {
          "context": "before tone 4",
          "result_tone": 2,
          "example_before": "一个",
          "example_pinyin": "yī + gè → yí gè",
          "meaning": "one (thing)"
        },
        {
          "context": "before tone 1/2/3",
          "result_tone": 4,
          "example_before": "一天",
          "example_pinyin": "yī + tiān → yì tiān",
          "meaning": "one day"
        },
        {
          "context": "standalone or at end",
          "result_tone": 1,
          "example_before": "第一",
          "example_pinyin": "dì yī",
          "meaning": "number one"
        },
        {
          "context": "in a series/ordinal",
          "result_tone": 1,
          "example_before": "一、二、三",
          "example_pinyin": "yī, èr, sān",
          "meaning": "one, two, three"
        }
      ]
    },
    "bu": {
      "base_tone": 4,
      "rules": [
        {
          "context": "before tone 4",
          "result_tone": 2,
          "example_before": "不对",
          "example_pinyin": "bù + duì → bú duì",
          "meaning": "incorrect"
        },
        {
          "context": "before tone 1/2/3",
          "result_tone": 4,
          "example_before": "不好",
          "example_pinyin": "bù + hǎo → bù hǎo",
          "meaning": "not good"
        }
      ]
    }
  },
  "learn_content": {
    "rules": [
      "一 (yī) + Tone 4 → yí (2nd tone): yí gè, yí wèi, yí cì",
      "一 (yī) + Tone 1/2/3 → yì (4th tone): yì tiān, yì nián, yì qǐ",
      "一 alone or at end of phrase stays yī: dì yī, shí yī",
      "不 (bù) + Tone 4 → bú: bú duì, bú shì, bú cuò",
      "不 + any other tone stays bù: bù hǎo, bù lái, bù néng"
    ],
    "spelling_rules": [
      {
        "title": "一 (yī) tone sandhi spelling",
        "rule": "The written form always shows yī, but pronunciation changes by context",
        "examples": [
          {
            "pinyin": "yí gè",
            "note": "yī + tone 4 → yí (one, a measure word)",
            "audio_key": "yi2_ge4"
          },
          {
            "pinyin": "yì tiān",
            "note": "yī + tone 1 → yì (one day)",
            "audio_key": "yi4_tian1"
          },
          {
            "pinyin": "yì qiān",
            "note": "yī + tone 1 → yì (one thousand)",
            "audio_key": "yi4_qian1"
          },
          {
            "pinyin": "yì qǐ",
            "note": "yī + tone 3 → yì (together)",
            "audio_key": "yi4_qi3"
          },
          {
            "pinyin": "dì yī",
            "note": "yī at phrase-end stays yī (first)",
            "audio_key": "di4_yi1"
          },
          {
            "pinyin": "shí yī",
            "note": "yī at phrase-end stays yī (eleven)",
            "audio_key": "shi2_yi1"
          }
        ]
      },
      {
        "title": "不 (bù) tone sandhi spelling",
        "rule": "不 is always written bù, but becomes bú before a 4th-tone syllable",
        "examples": [
          {
            "pinyin": "bù hǎo",
            "note": "bù + tone 3 → stays bù (not good)",
            "audio_key": "bu4_hao3"
          },
          {
            "pinyin": "bù néng",
            "note": "bù + tone 2 → stays bù (cannot)",
            "audio_key": "bu4_neng2"
          },
          {
            "pinyin": "bú duì",
            "note": "bù + tone 4 → spoken: bú duì (incorrect)",
            "audio_key": "bu2_dui4"
          },
          {
            "pinyin": "bú shì",
            "note": "bù + tone 4 → spoken: bú shì (is not)",
            "audio_key": "bu2_shi4"
          },
          {
            "pinyin": "bú cuò",
            "note": "bù + tone 4 → spoken: bú cuò (not bad)",
            "audio_key": "bu2_cuo4"
          }
        ]
      },
      {
        "title": "Common sandhi pairs — listen and compare",
        "rule": "Practice these pairs to hear the tone change clearly",
        "examples": [
          {
            "pinyin": "yí gè",
            "note": "one (before tone 4)",
            "audio_key": "yi2_ge4"
          },
          {
            "pinyin": "yì tiān",
            "note": "one day (before tone 1)",
            "audio_key": "yi4_tian1"
          },
          {
            "pinyin": "bú duì",
            "note": "incorrect (before tone 4)",
            "audio_key": "bu2_dui4"
          },
          {
            "pinyin": "bù hǎo",
            "note": "not good (before tone 3)",
            "audio_key": "bu4_hao3"
          }
        ]
      }
    ]
  },
